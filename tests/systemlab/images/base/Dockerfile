# syntax=docker/dockerfile:1
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    container=docker

# Preserve apt cache across builds (BuildKit cache mount)
RUN rm -f /etc/apt/apt.conf.d/docker-clean; \
    echo 'Binary::apt::APT::Keep-Downloaded-Packages "true";' \
      > /etc/apt/apt.conf.d/keep-cache

# Use Azure-colocated apt mirror. GitHub Actions runners are Azure VMs;
# archive.ubuntu.com goes through Canonical's CDN which can be slow
# from Azure (30-60s per package observed on some runners, causing
# 45-min+ build timeouts). azure.archive.ubuntu.com is co-located.
RUN sed -i 's|http://archive.ubuntu.com|http://azure.archive.ubuntu.com|g' \
      /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null || \
    sed -i 's|http://archive.ubuntu.com|http://azure.archive.ubuntu.com|g' \
      /etc/apt/sources.list 2>/dev/null || true

# ---------- OS packages (everything Meridian expects on a VPS) ----------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    systemd systemd-sysv dbus \
    openssh-server openssh-client sudo \
    curl wget openssl ca-certificates \
    python3 python3-pip python3-venv \
    iproute2 iptables nftables netcat-openbsd \
    qrencode dnsutils jq unzip socat \
    ufw cron fail2ban unattended-upgrades apt-listchanges \
    apt-transport-https gnupg software-properties-common \
    procps psmisc less vim-tiny

# ---------- nginx from official repo (1.27+, http2 on; directive) ----------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    curl -fsSL https://nginx.org/keys/nginx_signing.key \
      -o /etc/apt/keyrings/nginx.asc \
    && chmod 644 /etc/apt/keyrings/nginx.asc \
    && . /etc/os-release \
    && echo "deb [signed-by=/etc/apt/keyrings/nginx.asc] \
       https://nginx.org/packages/ubuntu $VERSION_CODENAME nginx" \
       > /etc/apt/sources.list.d/nginx-official.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends nginx

# ---------- Docker CE (Meridian checks dpkg-query -s docker-ce) ----------
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
       -o /etc/apt/keyrings/docker.asc \
    && chmod a+r /etc/apt/keyrings/docker.asc \
    && echo "deb [arch=$(dpkg --print-architecture) \
       signed-by=/etc/apt/keyrings/docker.asc] \
       https://download.docker.com/linux/ubuntu \
       $(. /etc/os-release && echo $VERSION_CODENAME) stable" \
       > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
       docker-ce docker-ce-cli containerd.io docker-compose-plugin

# ---------- SSH ----------
RUN mkdir -p /run/sshd /root/.ssh \
    && chmod 700 /root/.ssh \
    && ssh-keygen -A \
    && printf 'PermitRootLogin yes\nPubkeyAuthentication yes\nPasswordAuthentication no\n' \
       > /etc/ssh/sshd_config.d/lab.conf

# Controller SSH access (generated by setup-fixtures.sh, not committed)
COPY tests/systemlab/fixtures/controller_authorized_keys /root/.ssh/authorized_keys
RUN chmod 600 /root/.ssh/authorized_keys

# ---------- Docker daemon config (nested: vfs driver, no iptables) ----------
RUN mkdir -p /etc/docker \
    && printf '{"storage-driver":"vfs","iptables":false}\n' \
       > /etc/docker/daemon.json

# ---------- systemd wiring ----------
RUN ln -sf /lib/systemd/system/ssh.service \
       /etc/systemd/system/multi-user.target.wants/ssh.service \
    && ln -sf /lib/systemd/system/docker.service \
       /etc/systemd/system/multi-user.target.wants/docker.service

# Mask noisy/unnecessary units
RUN systemctl mask \
    systemd-resolved.service \
    getty@tty1.service \
    console-getty.service \
    systemd-networkd-wait-online.service \
    2>/dev/null || true

RUN systemd-machine-id-setup 2>/dev/null || dbus-uuidgen --ensure=/etc/machine-id || true

STOPSIGNAL SIGRTMIN+3
VOLUME ["/var/lib/docker"]
CMD ["/sbin/init"]
