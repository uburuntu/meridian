   ]},
  {'name': 'Nordic Design Lab', 'tag': 'Minimal design, maximum impact', 'type': 'design',
   'features': [
     {'icon': '&#9998;', 'title': 'Brand Identity', 'desc': 'Logos, typography, and visual systems that tell your story.'},
     {'icon': '&#128187;', 'title': 'Web Design', 'desc': 'Responsive websites built with clean code and modern standards.'},
     {'icon': '&#127912;', 'title': 'UI/UX', 'desc': 'User-centered interfaces designed for clarity and engagement.'}
   ]},
  {'name': 'Pinnacle Engineering', 'tag': 'Precision engineering for complex challenges', 'type': 'engineering',
   'features': [
     {'icon': '&#128295;', 'title': 'Prototyping', 'desc': 'Rapid iteration from concept to functional prototype.'},
     {'icon': '&#128202;', 'title': 'Simulation', 'desc': 'Computational modeling and stress analysis for critical systems.'},
     {'icon': '&#9878;', 'title': 'Compliance', 'desc': 'Regulatory alignment and quality assurance processes.'}
   ]},
  {'name': 'Greenfield Analytics', 'tag': 'Turn raw data into clear decisions', 'type': 'analytics',
   'features': [
     {'icon': '&#128200;', 'title': 'Dashboards', 'desc': 'Real-time visualization of your key business metrics.'},
     {'icon': '&#128270;', 'title': 'Research', 'desc': 'Market analysis and competitive intelligence reports.'},
     {'icon': '&#9889;', 'title': 'Automation', 'desc': 'Automated reporting pipelines that save hours every week.'}
   ]},
  {'name': 'Clearwater Solutions', 'tag': 'Cloud infrastructure, simplified', 'type': 'cloud',
   'features': [
     {'icon': '&#9729;', 'title': 'Migration', 'desc': 'Seamless transition from on-premise to cloud environments.'},
     {'icon': '&#128274;', 'title': 'Security', 'desc': 'Zero-trust architecture and continuous compliance monitoring.'},
     {'icon': '&#128736;', 'title': 'DevOps', 'desc': 'CI/CD pipelines and infrastructure as code.'}
   ]},
  {'name': 'Atlas Digital Media', 'tag': 'Stories that connect brands to people', 'type': 'media',
   'features': [
     {'icon': '&#127909;', 'title': 'Video', 'desc': 'Brand films, product demos, and social media content.'},
     {'icon': '&#128247;', 'title': 'Photography', 'desc': 'Professional product and lifestyle photography.'},
     {'icon': '&#128240;', 'title': 'Content', 'desc': 'SEO-optimized articles, whitepapers, and case studies.'}
   ]},
  {'name': 'Ironwood Logistics', 'tag': 'Reliable supply chain management worldwide', 'type': 'logistics',
   'features': [
     {'icon': '&#128666;', 'title': 'Shipping', 'desc': 'Global freight forwarding with real-time tracking.'},
     {'icon': '&#128230;', 'title': 'Warehousing', 'desc': 'Strategically located fulfillment centers.'},
     {'icon': '&#128196;', 'title': 'Customs', 'desc': 'Import/export documentation and regulatory compliance.'}
   ]},
