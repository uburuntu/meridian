  {'bg': 'linear-gradient(135deg,#22543d,#38a169)', 'accent': '#38a169', 'light': '#f0fff4'},
  {'bg': 'linear-gradient(135deg,#553c9a,#805ad5)', 'accent': '#805ad5', 'light': '#faf5ff'},
  {'bg': 'linear-gradient(135deg,#744210,#d69e2e)', 'accent': '#b7791f', 'light': '#fffff0'},
  {'bg': 'linear-gradient(135deg,#742a2a,#e53e3e)', 'accent': '#c53030', 'light': '#fff5f5'},
  {'bg': 'linear-gradient(135deg,#234e52,#319795)', 'accent': '#319795', 'light': '#e6fffa'},
  {'bg': 'linear-gradient(135deg,#1a202c,#2d3748)', 'accent': '#2d3748', 'light': '#edf2f7'}
