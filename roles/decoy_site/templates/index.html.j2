{% set seed = (inventory_hostname + (ansible_host | default('x'))) | hash('md5') %}
{% set theme_idx = (seed[0:4] | int(base=16)) % (themes | length) %}
{% set biz_idx = (seed[4:8] | int(base=16)) % (businesses | length) %}
{% set theme = themes[theme_idx] %}
{% set biz = businesses[biz_idx] %}
{% set site_name = decoy_site_title if decoy_site_title != 'Meridian Digital Solutions' else biz.name %}
{% set site_tag = decoy_site_tagline if decoy_site_tagline != 'Modern technology consulting for growing businesses' else biz.tag %}
{% set layout_var = (seed[8:10] | int(base=16)) % 3 %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site_name }}</title>
<meta name="description" content="{{ site_tag }}">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;color:#2d3748;line-height:1.7;background:#fff}
{% if layout_var == 0 %}
.hero{background:{{ theme.bg }};color:#fff;padding:100px 24px;text-align:center}
.hero h1{font-size:2.8rem;font-weight:700;margin-bottom:16px;letter-spacing:-.02em}
.hero p{font-size:1.15rem;opacity:.85;max-width:520px;margin:0 auto}
{% elif layout_var == 1 %}
.hero{background:{{ theme.bg }};color:#fff;padding:80px 24px;text-align:left;display:flex;align-items:center;justify-content:center}
.hero-inner{max-width:600px}
.hero h1{font-size:2.4rem;font-weight:800;margin-bottom:12px;line-height:1.15}
.hero p{font-size:1.1rem;opacity:.8;line-height:1.6}
{% else %}
.hero{background:{{ theme.light }};color:#1a202c;padding:100px 24px;text-align:center;border-bottom:4px solid {{ theme.accent }}}
.hero h1{font-size:2.6rem;font-weight:700;margin-bottom:16px;color:{{ theme.accent }}}
.hero p{font-size:1.1rem;color:#4a5568;max-width:520px;margin:0 auto}
{% endif %}
.features{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:40px;padding:72px 24px;max-width:960px;margin:0 auto}
.feature{text-align:center}
.feature .ic{font-size:2rem;margin-bottom:14px}
.feature h3{font-size:1.05rem;margin-bottom:6px;color:{{ theme.accent }};font-weight:600}
.feature p{font-size:.92rem;color:#4a5568;line-height:1.6}
.foot{text-align:center;padding:36px 24px;color:#a0aec0;font-size:.82rem;border-top:1px solid #e2e8f0}
nav{background:#fff;padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #e2e8f0}
nav .logo{font-weight:700;font-size:1.1rem;color:{{ theme.accent }}}
nav .links{display:flex;gap:24px}
nav a{text-decoration:none;color:#4a5568;font-size:.9rem}
nav a:hover{color:{{ theme.accent }}}
.cta{display:inline-block;margin-top:28px;padding:14px 32px;background:{% if layout_var == 2 %}{{ theme.accent }}{% else %}rgba(255,255,255,.15){% endif %};color:{% if layout_var == 2 %}#fff{% else %}#fff{% endif %};border:{% if layout_var == 2 %}none{% else %}1px solid rgba(255,255,255,.3){% endif %};border-radius:6px;font-size:.95rem;font-weight:500;text-decoration:none;backdrop-filter:blur(4px)}
@media(max-width:640px){.hero h1{font-size:1.8rem}.hero{padding:60px 20px}nav .links{display:none}}
</style>
</head>
<body>
<nav>
  <div class="logo">{{ site_name }}</div>
  <div class="links">
    <a href="#">Services</a>
    <a href="#">About</a>
    <a href="#">Contact</a>
  </div>
</nav>
{% if layout_var == 1 %}
<div class="hero"><div class="hero-inner">
  <h1>{{ site_name }}</h1>
  <p>{{ site_tag }}</p>
  <a href="#" class="cta">Learn More</a>
</div></div>
{% else %}
<div class="hero">
  <h1>{{ site_name }}</h1>
  <p>{{ site_tag }}</p>
  <a href="#" class="cta">Get Started</a>
</div>
{% endif %}
<div class="features">
{% for f in biz.features %}
  <div class="feature">
    <div class="ic">{{ f.icon }}</div>
    <h3>{{ f.title }}</h3>
    <p>{{ f.desc }}</p>
  </div>
{% endfor %}
</div>
<div class="foot">
  &copy; {{ ansible_date_time.year }} {{ site_name }}. All rights reserved.
</div>
</body>
</html>
