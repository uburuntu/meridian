<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Connection Setup</title>
<style>
:root {
  --bg: #0c0e14; --bg2: #12151e; --sf: #181c28; --sf2: #1e2333;
  --br: #282d3e; --br2: #353b52;
  --tx: #e8eaf0; --tx2: #8b90a8; --tx3: #555a72;
  --blue: #5b9cf5; --blue-bg: #5b9cf512; --blue-br: #5b9cf530;
  --amber: #e5a44e; --amber-bg: #e5a44e12; --amber-br: #e5a44e30;
  --green: #4cd68a; --red: #ef6b6b;
  --r: 10px; --r2: 14px;
}
@media(prefers-color-scheme:light){:root{
  --bg: #f0f2f5; --bg2: #e8ebf0; --sf: #fff; --sf2: #f7f8fa;
  --br: #d8dce6; --br2: #c0c6d4;
  --tx: #1a1e2e; --tx2: #5a6078; --tx3: #8a90a8;
  --blue: #2b7de9; --blue-bg: #2b7de90a; --blue-br: #2b7de925;
  --amber: #c4882a; --amber-bg: #c4882a0a; --amber-br: #c4882a25;
  --green: #1a9d5a; --red: #d44;
}}
*{margin:0;padding:0;box-sizing:border-box}
body{
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
  background:var(--bg);color:var(--tx);-webkit-font-smoothing:antialiased;
  min-height:100vh;
  background-image:radial-gradient(var(--br) .5px,transparent .5px);
  background-size:24px 24px;
}
.wrap{max-width:460px;margin:0 auto;padding:24px 16px 40px}
.hdr{text-align:center;padding:20px 0 28px}
.hdr h1{font-size:1.35rem;font-weight:700;letter-spacing:-.02em;margin-bottom:4px}
.hdr p{font-size:.82rem;color:var(--tx2)}
.card{
  background:var(--sf);border:1px solid var(--br);
  border-radius:var(--r2);padding:20px;margin-bottom:14px;
  position:relative;overflow:hidden;
}
.card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
}
.card-blue::before{background:var(--blue)}
.card-amber::before{background:var(--amber)}
.card-label{
  display:inline-flex;align-items:center;gap:6px;
  font-size:.7rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;
  padding:3px 10px 3px 8px;border-radius:99px;margin-bottom:12px;
}
.card-blue .card-label{background:var(--blue-bg);border:1px solid var(--blue-br);color:var(--blue)}
.card-amber .card-label{background:var(--amber-bg);border:1px solid var(--amber-br);color:var(--amber)}
.card-label i{width:5px;height:5px;border-radius:50%;display:inline-block}
.card-blue .card-label i{background:var(--blue)}
.card-amber .card-label i{background:var(--amber)}
.card-desc{font-size:.82rem;color:var(--tx2);margin-bottom:16px;line-height:1.4}
.open-btn{
  display:block;width:100%;padding:13px;border-radius:var(--r);
  font-size:.92rem;font-weight:600;text-align:center;text-decoration:none;
  border:none;cursor:pointer;transition:filter .06s,transform .06s;
  letter-spacing:-.01em;
}
.open-btn:hover{filter:brightness(1.08)}
.open-btn:active{transform:scale(.985)}
.card-blue .open-btn{background:var(--blue);color:#fff}
.card-amber .open-btn{background:var(--amber);color:#fff}
.qr{text-align:center;margin:16px 0}
.qr img{width:200px;height:200px;border-radius:8px;background:#fff;padding:6px}
.url{
  background:var(--bg2);border:1px solid var(--br);
  border-radius:8px;padding:10px 12px;
  font-family:'SF Mono',SFMono-Regular,Menlo,Consolas,monospace;
  font-size:.65rem;word-break:break-all;color:var(--tx3);
  cursor:pointer;transition:border-color .06s;line-height:1.5;
  position:relative;
}
.url:hover{border-color:var(--tx2)}
.url-hint{
  display:block;text-align:right;margin-top:6px;
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  font-size:.6rem;color:var(--tx3);opacity:.5;
  text-transform:uppercase;letter-spacing:.04em;font-weight:500;
}
.apps{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px}
.app{
  display:flex;flex-direction:column;align-items:center;gap:2px;
  padding:12px 8px;background:var(--bg2);border:1px solid var(--br);
  border-radius:var(--r);text-decoration:none;color:var(--tx);
  font-size:.82rem;font-weight:500;transition:border-color .06s;
}
.app:hover{border-color:var(--tx2)}
.app.detected{border-color:var(--blue);background:var(--blue-bg)}
.app span{font-size:.68rem;color:var(--tx3);font-weight:400}
.steps{counter-reset:s;margin-top:14px}
.step{
  display:flex;gap:12px;padding:10px 0;
  border-bottom:1px solid var(--br);font-size:.82rem;color:var(--tx2);line-height:1.5;
}
.step:last-child{border-bottom:none}
.step::before{
  counter-increment:s;content:counter(s);
  min-width:22px;height:22px;border-radius:50%;
  background:var(--bg2);border:1px solid var(--br);
  font-size:.68rem;font-weight:600;color:var(--tx3);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;
}
.warn{
  background:var(--amber-bg);border:1px solid var(--amber-br);
  border-radius:var(--r2);padding:16px;margin-top:14px;
}
.warn h3{font-size:.82rem;color:var(--amber);margin-bottom:4px;font-weight:600}
.warn p{font-size:.78rem;color:var(--tx2);line-height:1.5}
.foot{
  text-align:center;padding:24px 0 8px;font-size:.7rem;color:var(--tx3);
  display:flex;flex-direction:column;gap:6px;align-items:center;
}
.foot a{color:var(--tx2);text-decoration:none;transition:color .06s}
.foot a:hover{color:var(--blue)}
.foot .links{display:flex;gap:4px;align-items:center}
.foot .links .sep{opacity:.3}
.toast{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(8px);
  background:var(--green);color:#0c0e14;padding:8px 20px;
  border-radius:99px;font-size:.82rem;font-weight:600;
  opacity:0;transition:opacity .08s,transform .08s;pointer-events:none;z-index:10;
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
</style>
</head>
<body>
<div class="wrap">

<div class="hdr">
  <h1 data-t="title">Connection Setup</h1>
  <p data-t="subtitle">Scan QR code or tap to open in your app</p>
</div>

<!-- Primary -->
<div class="card card-blue">
  <div class="card-label"><i></i> <span data-t="primary">Primary</span></div>
  <p class="card-desc" data-t="primary.desc">Fastest route. Use this as your default connection.</p>
  <a href="{{ vless_reality_url }}" class="open-btn" data-t="open">Open in App</a>
  <div class="qr"><img src="data:image/png;base64,{{ reality_qr_b64_local.stdout }}" alt="QR" loading="lazy"></div>
  <div class="url" onclick="cp(this)" data-url="{{ vless_reality_url }}">{{ vless_reality_url }}<span class="url-hint"><span data-t="copy.hint">tap to copy</span></span></div>
</div>

{% if xhttp_enabled | default(false) | bool %}
<!-- XHTTP -->
<div class="card card-blue">
  <div class="card-label"><i></i> XHTTP</div>
  <p class="card-desc">Enhanced stealth via XHTTP transport. Harder to detect under traffic analysis.</p>
  <a href="{{ vless_xhttp_url }}" class="open-btn" data-t="open">Open in App</a>
  <div class="qr"><img src="data:image/png;base64,{{ xhttp_qr_b64_local.stdout }}" alt="QR" loading="lazy"></div>
  <div class="url" onclick="cp(this)" data-url="{{ vless_xhttp_url }}">{{ vless_xhttp_url }}<span class="url-hint"><span data-t="copy.hint">tap to copy</span></span></div>
</div>
{% endif %}

{% if domain_mode | bool %}
<!-- Backup -->
<div class="card card-amber">
  <div class="card-label"><i></i> <span data-t="backup">Backup</span></div>
  <p class="card-desc" data-t="backup.desc">CDN fallback. Use if the primary connection is blocked.</p>
  <a href="{{ vless_wss_url }}" class="open-btn" data-t="open">Open in App</a>
  <div class="qr"><img src="data:image/png;base64,{{ wss_qr_b64_local.stdout }}" alt="QR" loading="lazy"></div>
  <div class="url" onclick="cp(this)" data-url="{{ vless_wss_url }}">{{ vless_wss_url }}<span class="url-hint"><span data-t="copy.hint">tap to copy</span></span></div>
</div>
{% endif %}

<!-- Apps -->
<div class="card">
  <div style="font-size:.82rem;font-weight:600;margin-bottom:4px" data-t="apps">Client Apps</div>
  <p class="card-desc" data-t="apps.desc">Install one, then tap "Open in App" or scan the QR code.</p>
  <div class="apps" id="apps">
    <a class="app" href="https://apps.apple.com/app/v2raytun/id6476628951" target="_blank" data-os="iOS">v2RayTun<span>iOS</span></a>
    <a class="app" href="https://github.com/2dust/v2rayNG/releases/latest" target="_blank" data-os="Android">v2rayNG<span>Android</span></a>
    <a class="app" href="https://github.com/hiddify/hiddify-app/releases/latest" target="_blank" data-os="All">Hiddify<span>All platforms</span></a>
    <a class="app" href="https://github.com/2dust/v2rayN/releases/latest" target="_blank" data-os="Windows">v2rayN<span>Windows</span></a>
  </div>
</div>

<!-- Steps -->
<div class="card">
  <div style="font-size:.82rem;font-weight:600;margin-bottom:4px" data-t="setup">Quick Setup</div>
  <div class="steps">
    <div class="step" data-t="step1">Install a client app from the list above</div>
    <div class="step" data-t="step2">Tap "Open in App" — the connection imports automatically</div>
    <div class="step" data-t="step3">Or scan the QR code from another device</div>
    <div class="step" data-t="step4">Activate the connection in the app</div>
  </div>
</div>

<!-- Warning -->
<div class="warn">
  <h3 data-t="clock">Clock Sync Required</h3>
  <p data-t="clock.desc">Your device clock must be accurate within 30 seconds. Go to Settings &gt; Date &amp; Time &gt; enable "Set Automatically".</p>
</div>

<div class="warn" style="border-color:#d4a24e33;background:#d4a24e08">
  <h3 data-t="ping">Not connecting?</h3>
  <p data-t="ping.desc">Test if the server is reachable from your device: <a href="https://meridian.msu.rocks/ping?ip={{ server_public_ip }}{% if domain | default('') %}&domain={{ domain }}{% endif %}" target="_blank" style="color:#d4a24e">Run ping test</a></p>
</div>

<!-- Footer -->
<div class="foot">
  <div class="links">
    <a href="https://meridian.msu.rocks" target="_blank">Powered by Meridian</a>
    <span class="sep">&middot;</span>
    <a href="https://github.com/uburuntu/meridian" target="_blank">GitHub</a>
  </div>
  <div>{{ ansible_date_time.iso8601 }}</div>
</div>

</div>

<div class="toast" id="toast">Copied</div>

<script>
function cp(el){
  var u=el.getAttribute('data-url');if(!u)return;
  if(navigator.clipboard)navigator.clipboard.writeText(u).then(flash);
  else{var t=document.createElement('textarea');t.value=u;t.style.cssText='position:fixed;opacity:0';document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t);flash()}
}
function flash(){var t=document.getElementById('toast');t.classList.add('show');setTimeout(function(){t.classList.remove('show')},1200)}
/* i18n — auto-detect browser language */
!function(){
  var T={
    ru:{title:'Настройка подключения',subtitle:'Отсканируйте QR-код или нажмите, чтобы открыть в приложении',primary:'Основной',backup:'Резервный','primary.desc':'Самый быстрый маршрут. Используйте как основное подключение.','backup.desc':'CDN-фолбэк. Используйте, если основное подключение заблокировано.',open:'Открыть в приложении','copy.hint':'нажмите для копирования',apps:'Приложения','apps.desc':'Установите одно из них, затем нажмите «Открыть в приложении» или отсканируйте QR-код.',setup:'Быстрая настройка',step1:'Установите клиентское приложение из списка выше',step2:'Нажмите «Открыть в приложении» — подключение импортируется автоматически',step3:'Или отсканируйте QR-код с другого устройства',step4:'Активируйте подключение в приложении',clock:'Синхронизация часов','clock.desc':'Часы устройства должны быть точными с отклонением не более 30 секунд. Откройте Настройки > Дата и время > включите «Автоматически».'},
    fa:{title:'تنظیم اتصال',subtitle:'کد QR را اسکن کنید یا برای باز کردن در برنامه ضربه بزنید',primary:'اصلی',backup:'پشتیبان','primary.desc':'سریع‌ترین مسیر. به عنوان اتصال پیش‌فرض استفاده کنید.','backup.desc':'فال‌بک CDN. اگر اتصال اصلی مسدود شد استفاده کنید.',open:'باز کردن در برنامه','copy.hint':'برای کپی ضربه بزنید',apps:'برنامه‌ها','apps.desc':'یکی را نصب کنید، سپس «باز کردن در برنامه» را بزنید یا کد QR را اسکن کنید.',setup:'راه‌اندازی سریع',step1:'یک برنامه کلاینت از لیست بالا نصب کنید',step2:'«باز کردن در برنامه» را بزنید — اتصال به‌طور خودکار وارد می‌شود',step3:'یا کد QR را از دستگاه دیگری اسکن کنید',step4:'اتصال را در برنامه فعال کنید',clock:'همگام‌سازی ساعت','clock.desc':'ساعت دستگاه باید با دقت ۳۰ ثانیه تنظیم باشد. به تنظیمات > تاریخ و ساعت > «تنظیم خودکار» بروید.'},
    zh:{title:'连接设置',subtitle:'扫描二维码或点击在应用中打开',primary:'主要',backup:'备用','primary.desc':'最快路线。作为默认连接使用。','backup.desc':'CDN 备用通道。主连接被封锁时使用。',open:'在应用中打开','copy.hint':'点击复制',apps:'客户端应用','apps.desc':'安装一个应用，然后点击"在应用中打开"或扫描二维码。',setup:'快速设置',step1:'从上方列表安装一个客户端应用',step2:'点击"在应用中打开"——连接自动导入',step3:'或从另一台设备扫描二维码',step4:'在应用中激活连接',clock:'时钟同步','clock.desc':'设备时钟必须精确到 30 秒以内。前往设置 > 日期与时间 > 启用"自动设置"。'}
  };
  var bl=(navigator.language||'').slice(0,2),lang=T[bl]?bl:null;
  if(lang){
    document.querySelectorAll('[data-t]').forEach(function(el){
      var k=el.dataset.t,v=T[lang][k];if(v)el.textContent=v;
    });
    if(lang==='fa')document.documentElement.dir='rtl';
  }
}();
!function(){
  var ua=navigator.userAgent,os=null;
  if(/iPhone|iPad|iPod/i.test(ua))os='iOS';
  else if(/Android/i.test(ua))os='Android';
  else if(/Win/i.test(ua))os='Windows';
  if(os)document.querySelectorAll('.app').forEach(function(a){if(a.getAttribute('data-os')===os)a.classList.add('detected')});
}();
</script>
</body>
</html>
