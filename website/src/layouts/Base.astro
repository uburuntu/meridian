---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'One command deploys a fully configured, undetectable proxy server. Open source.',
  ogImage = '/img/og.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const locale = Astro.currentLocale ?? 'en';
const dir = locale === 'fa' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <!-- Early locale detection: prevents RTL layout shift for Farsi users -->
    <!-- Early theme detection: prevents flash of wrong color scheme -->
    <script is:inline>
      (function(){
        var l=localStorage.getItem('meridian-lang');
        if(l){document.documentElement.lang=l;if(l==='fa')document.documentElement.dir='rtl';}
        var t=localStorage.getItem('meridian-theme');
        if(t==='dark'||t==='light')document.documentElement.dataset.theme=t;
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="referrer" content="no-referrer" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : locale === 'fa' ? 'fa_IR' : locale === 'ru' ? 'ru_RU' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32.png" />
    <link rel="apple-touch-icon" href="/img/logo-180.png" />

    <meta name="generator" content={Astro.generator} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <slot />
    <Footer />

    <!-- i18n: client-side language switching -->
    <script>
      import { detectLocale, setLang } from '../i18n/index';
      import { translations } from '../i18n/translations';

      function updateDocsLinks(lang: string) {
        if (lang === 'en') return;
        document.querySelectorAll<HTMLAnchorElement>('a[href*="/docs/en/"]').forEach((a) => {
          a.href = a.href.replace('/docs/en/', `/docs/${lang}/`);
        });
      }

      /**
       * On docs pages, read available locales from the embedded JSON and
       * update the header LanguagePicker: disable unavailable languages,
       * highlight the current locale.
       */
      function initDocsLocales(currentLang: string) {
        const el = document.getElementById('docs-locales');
        if (!el) return null;
        try {
          const locales = JSON.parse(el.textContent || '[]') as { code: string; label: string; href: string }[];
          const available = new Set(locales.map((l) => l.code));
          // Update picker button states
          document.querySelectorAll('.lang-picker__btn').forEach((btn) => {
            const code = (btn as HTMLElement).dataset.lang!;
            if (!available.has(code)) {
              btn.classList.add('lang-picker__btn--unavailable');
            } else {
              btn.classList.remove('lang-picker__btn--unavailable');
            }
            btn.classList.toggle('lang-picker__btn--active', code === currentLang);
          });
          return locales;
        } catch {
          return null;
        }
      }

      // Auto-detect and apply language on load
      const lang = detectLocale();
      const docsLocales = initDocsLocales(lang);

      if (lang !== 'en') {
        setLang(lang, translations);
        updateDocsLinks(lang);
      } else if (!docsLocales) {
        // Non-docs page: still update picker active state for English
        document.querySelectorAll('.lang-picker__btn').forEach((btn) => {
          btn.classList.toggle('lang-picker__btn--active', (btn as HTMLElement).dataset.lang === 'en');
        });
      }

      // Handle language picker clicks
      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.lang-picker__btn') as HTMLButtonElement;
        if (!btn || btn.classList.contains('lang-picker__btn--unavailable')) return;
        const lang = btn.dataset.lang as 'en' | 'ru' | 'fa' | 'zh';
        if (!lang) return;

        // On docs pages, navigate to the locale-specific URL
        const localesEl = document.getElementById('docs-locales');
        if (localesEl) {
          try {
            const locales = JSON.parse(localesEl.textContent || '[]') as { code: string; href: string }[];
            const target = locales.find((l) => l.code === lang);
            if (target) {
              localStorage.setItem('meridian-lang', lang);
              location.href = target.href;
              return;
            }
          } catch {}
        }

        // Non-docs pages: existing behavior
        if (lang === 'en') {
          localStorage.setItem('meridian-lang', 'en');
          location.reload();
        } else {
          setLang(lang, translations);
          updateDocsLinks(lang);
        }
      });
    </script>

    <!-- Copy buttons on prose code blocks -->
    <script is:inline>
      (function() {
        var icon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
        var check = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
        document.querySelectorAll('.prose pre').forEach(function(pre) {
          var code = pre.querySelector('code');
          if (!code) return;
          var btn = document.createElement('button');
          btn.className = 'code-copy';
          btn.setAttribute('aria-label', 'Copy code');
          btn.innerHTML = icon;
          btn.addEventListener('click', function() {
            navigator.clipboard.writeText(code.textContent || '').then(function() {
              btn.innerHTML = check;
              btn.setAttribute('data-copied', '');
              setTimeout(function() {
                btn.innerHTML = icon;
                btn.removeAttribute('data-copied');
              }, 1500);
            });
          });
          pre.appendChild(btn);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
