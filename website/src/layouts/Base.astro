---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'One command deploys a fully configured, undetectable proxy server. Open source.',
  ogImage = '/img/og.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const locale = Astro.currentLocale ?? 'en';
const dir = locale === 'fa' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32.png" />
    <link rel="apple-touch-icon" href="/img/logo-180.png" />

    <!-- Fonts: preconnect + load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Source+Sans+3:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta name="generator" content={Astro.generator} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <slot />
    <Footer />

    <!-- i18n: client-side language switching -->
    <script>
      import { detectLocale, setLang } from '../i18n/index';
      import { translations } from '../i18n/translations';

      // Auto-detect and apply language on load
      const lang = detectLocale();
      if (lang !== 'en') {
        setLang(lang, translations);
      } else {
        // Still update picker active state for English
        document.querySelectorAll('.lang-picker__btn').forEach((btn) => {
          btn.classList.toggle('lang-picker__btn--active', (btn as HTMLElement).dataset.lang === 'en');
        });
      }

      // Handle language picker clicks
      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.lang-picker__btn') as HTMLButtonElement;
        if (!btn) return;
        const lang = btn.dataset.lang as 'en' | 'ru' | 'fa' | 'zh';
        if (!lang) return;

        if (lang === 'en') {
          // Reload to get build-time English content
          localStorage.setItem('meridian-lang', 'en');
          location.reload();
        } else {
          setLang(lang, translations);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
