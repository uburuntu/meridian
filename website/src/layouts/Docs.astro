---
/**
 * Docs layout — sidebar + content area + TOC + locale switcher.
 * Used by docs/[...slug].astro for all documentation pages.
 */
import Base from './Base.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import TOC from '../components/TOC.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface NavItem {
  title: string;
  slug: string;
  order: number;
}

interface NavSection {
  label: string;
  items: NavItem[];
}

interface LocaleOption {
  code: string;
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  headings: Heading[];
  sections: NavSection[];
  currentSlug: string;
  locale?: string;
  availableLocales?: LocaleOption[];
  mdPath?: string;
}

const { title, description, headings, sections, currentSlug, locale = 'en', availableLocales = [], mdPath } = Astro.props;
const dir = locale === 'fa' ? 'rtl' : 'ltr';
---

<Base title={`${title} — Meridian Docs`} description={description}>
  {mdPath && <link slot="head" rel="alternate" type="text/markdown" href={mdPath} />}
  <div class="docs-layout" dir={dir}>
    <DocsSidebar sections={sections} currentSlug={currentSlug} />

    <main id="main" class="docs-content">
      {availableLocales.length > 1 && (
        <div class="docs-locale-switcher">
          {availableLocales.map((l) => (
            <a
              href={l.href}
              class:list={['docs-locale-btn', { 'docs-locale-btn--active': l.code === locale }]}
            >
              {l.label}
            </a>
          ))}
        </div>
      )}
      <article class="docs-article" data-pagefind-body>
        <h1>{title}</h1>
        <slot />
      </article>
    </main>

    <TOC headings={headings} />
  </div>
</Base>

<style is:global>
  .docs-layout {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    padding: 56px 24px 0;
    gap: 40px;
  }

  .docs-content {
    flex: 1;
    min-width: 0;
    padding: 32px 0 80px;
  }

  .docs-article {
    max-width: 680px;
  }

  .docs-article h1 {
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--b1);
  }

  /* Locale switcher */
  .docs-locale-switcher {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
  }
  .docs-locale-btn {
    padding: 4px 10px;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--t3);
    text-decoration: none;
    border: 1px solid var(--b1);
    border-radius: 4px;
    transition: color 0.1s, border-color 0.1s;
  }
  .docs-locale-btn:hover {
    color: var(--t1);
    border-color: var(--b2);
  }
  .docs-locale-btn--active {
    color: var(--ac);
    border-color: var(--ac);
    background: var(--ac2);
  }

  /* Markdown content styles */
  .docs-article h2 {
    margin-top: 48px;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--b1);
  }

  .docs-article h3 {
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .docs-article p {
    color: var(--t2);
    font-size: 0.92rem;
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .docs-article ul, .docs-article ol {
    color: var(--t2);
    font-size: 0.92rem;
    line-height: 1.75;
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .docs-article li {
    margin-bottom: 6px;
  }

  .docs-article strong {
    color: var(--t1);
    font-weight: 500;
  }

  .docs-article em {
    color: var(--t1);
    font-style: italic;
  }

  .docs-article code {
    font-family: var(--mono);
    font-size: 0.82rem;
    background: var(--s1);
    padding: 2px 7px;
    border-radius: 4px;
    border: 1px solid var(--b1);
    color: var(--t1);
  }

  .docs-article pre {
    background: var(--s1);
    border: 1px solid var(--b1);
    border-radius: var(--r);
    padding: 18px 22px;
    margin: 16px 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .docs-article pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.65;
    color: var(--t1);
  }

  .docs-article a {
    color: var(--ac);
    text-decoration: underline;
    text-decoration-color: var(--ac2);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.1s;
  }
  .docs-article a:hover {
    text-decoration-color: var(--ac);
    color: var(--ac);
  }

  .docs-article table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.84rem;
    margin: 16px 0;
  }

  .docs-article th {
    text-align: left;
    color: var(--t3);
    font-weight: 500;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 8px 14px;
    border-bottom: 1px solid var(--b2);
  }

  .docs-article td {
    padding: 8px 14px;
    border-bottom: 1px solid var(--b1);
    color: var(--t2);
    vertical-align: top;
  }

  .docs-article td:first-child {
    color: var(--t1);
    font-family: var(--mono);
    font-size: 0.78rem;
  }

  .docs-article tr:last-child td {
    border-bottom: none;
  }

  .docs-article blockquote {
    border-left: 3px solid var(--ac);
    padding: 12px 18px;
    margin: 16px 0;
    background: var(--ac3);
    border-radius: 0 var(--r) var(--r) 0;
    color: var(--t2);
    font-size: 0.9rem;
  }

  .docs-article hr {
    border: none;
    height: 1px;
    background: var(--b1);
    margin: 40px 0;
  }

  .docs-article img {
    max-width: 100%;
    height: auto;
    border-radius: var(--r);
    border: 1px solid var(--b1);
  }

  /* RTL support for docs */
  [dir="rtl"] .docs-article th { text-align: right; }
  [dir="rtl"] .docs-article { direction: rtl; }
  [dir="rtl"] .docs-article ul,
  [dir="rtl"] .docs-article ol {
    padding-left: 0;
    padding-right: 24px;
  }
  [dir="rtl"] .docs-article blockquote {
    border-left: none;
    border-right: 3px solid var(--ac);
    border-radius: var(--r) 0 0 var(--r);
  }

  @media (max-width: 860px) {
    .docs-layout {
      padding-top: 52px;
    }
    .docs-content {
      padding: 24px 0 60px;
    }
  }
</style>
