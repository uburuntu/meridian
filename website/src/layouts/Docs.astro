---
/**
 * Docs layout — sidebar + content area + TOC + locale switcher.
 * Used by docs/[...slug].astro for all documentation pages.
 */
import Base from './Base.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import TOC from '../components/TOC.astro';
import Mermaid from '../components/Mermaid.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface NavItem {
  title: string;
  slug: string;
  order: number;
}

interface NavSection {
  label: string;
  items: NavItem[];
}

interface LocaleOption {
  code: string;
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  headings: Heading[];
  sections: NavSection[];
  currentSlug: string;
  locale?: string;
  availableLocales?: LocaleOption[];
  mdPath?: string;
}

const { title, description, headings, sections, currentSlug, locale = 'en', availableLocales = [], mdPath } = Astro.props;
const dir = locale === 'fa' ? 'rtl' : 'ltr';
---

<Base title={`${title} — Meridian Docs`} description={description}>
  {mdPath && <link slot="head" rel="alternate" type="text/markdown" href={mdPath} />}
  {availableLocales.map((l) => (
    <link slot="head" rel="alternate" hreflang={l.code === 'zh' ? 'zh-Hans' : l.code} href={l.href} />
  ))}
  <div class="docs-layout" dir={dir}>
    <DocsSidebar sections={sections} currentSlug={currentSlug} />

    <main id="main" class="docs-content">
      {availableLocales.length > 1 && (
        <div class="docs-locale-switcher">
          {availableLocales.map((l) => (
            <a
              href={l.href}
              class:list={['docs-locale-btn', { 'docs-locale-btn--active': l.code === locale }]}
            >
              {l.label}
            </a>
          ))}
          {mdPath && (
            <a href={mdPath} class="docs-locale-btn docs-md-btn" title="View as Markdown">MD</a>
          )}
        </div>
      )}
      {!availableLocales.length && mdPath && (
        <div class="docs-locale-switcher">
          <a href={mdPath} class="docs-locale-btn docs-md-btn" title="View as Markdown">MD</a>
        </div>
      )}
      <article class="docs-article prose" data-pagefind-body>
        <h1>{title}</h1>
        <slot />
      </article>
    </main>

    <TOC headings={headings} />
  </div>
  <Mermaid />
</Base>

<style is:global>
  @import '../styles/prose.css';

  .docs-layout {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    padding: 56px 24px 0;
    gap: 40px;
  }

  .docs-content {
    flex: 1;
    min-width: 0;
    padding: 32px 0 80px;
  }

  .docs-article {
    max-width: 680px;
  }

  .docs-article h1 {
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--b1);
  }

  /* Locale switcher */
  .docs-locale-switcher {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
  }
  .docs-locale-btn {
    padding: 4px 10px;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--t3);
    text-decoration: none;
    border: 1px solid var(--b1);
    border-radius: 4px;
    transition: color 0.1s, border-color 0.1s;
  }
  .docs-locale-btn:hover {
    color: var(--t1);
    border-color: var(--b2);
  }
  .docs-locale-btn--active {
    color: var(--ac);
    border-color: var(--ac);
    background: var(--ac2);
  }
  .docs-md-btn {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
  }

  /* RTL support for docs */
  [dir="rtl"] .prose th { text-align: right; }
  [dir="rtl"] .prose { direction: rtl; }
  [dir="rtl"] .prose ul,
  [dir="rtl"] .prose ol {
    padding-left: 0;
    padding-right: 24px;
  }
  [dir="rtl"] .prose blockquote {
    border-left: none;
    border-right: 3px solid var(--ac);
    border-radius: var(--r) 0 0 var(--r);
  }

  @media (max-width: 860px) {
    .docs-layout {
      padding-top: 52px;
    }
    .docs-content {
      padding: 24px 0 60px;
    }
  }
</style>
