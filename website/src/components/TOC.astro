---
/**
 * TOC — Table of Contents (right rail).
 * Auto-generated from heading data passed as props.
 */
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <div class="toc" id="toc">
    <div class="toc__label">On this page</div>
    <nav aria-label="Table of contents">
      <ul class="toc__list">
        {filtered.map((h) => (
          <li class:list={[{ 'toc__indent': h.depth === 3 }]}>
            <a href={`#${h.slug}`} class="toc__link">{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}

<style>
  .toc {
    position: sticky;
    top: 68px;
    max-height: calc(100vh - 68px);
    overflow-y: auto;
    padding: 24px 0;
    width: 180px;
    flex-shrink: 0;
  }
  .toc__label {
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--t3);
    margin-bottom: 10px;
  }
  .toc__list {
    list-style: none;
  }
  .toc__link {
    display: block;
    padding: 3px 0;
    font-size: 0.75rem;
    color: var(--t3);
    text-decoration: none;
    transition: color 0.1s;
    line-height: 1.5;
    border-left: 1px solid var(--b1);
    padding-left: 12px;
  }
  .toc__link:hover {
    color: var(--t1);
    border-left-color: var(--ac);
  }
  .toc__indent .toc__link {
    padding-left: 24px;
  }

  @media (max-width: 1100px) {
    .toc {
      display: none;
    }
  }
</style>
