---
interface App {
  name: string;
  platform: string;
  url: string;
}

const apps: App[] = [
  { name: 'v2RayTun', platform: 'iOS', url: 'https://apps.apple.com/app/v2raytun/id6476628951' },
  { name: 'v2rayNG', platform: 'Android', url: 'https://github.com/2dust/v2rayNG/releases/latest' },
  { name: 'Hiddify', platform: 'All platforms', url: 'https://github.com/hiddify/hiddify-app/releases/latest' },
  { name: 'v2rayN', platform: 'Windows', url: 'https://github.com/2dust/v2rayN/releases/latest' },
];
---

<div class="app-grid">
  {apps.map((app) => (
    <a class="app-grid__item" href={app.url} target="_blank" rel="noopener">
      <span class="app-grid__name">{app.name}</span>
      <span class="app-grid__platform">{app.platform}</span>
    </a>
  ))}
</div>

<style>
  .app-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin: 16px 0;
  }
  .app-grid__item {
    background: var(--s1);
    border: 1px solid var(--b1);
    border-radius: var(--r);
    padding: 16px 12px;
    text-align: center;
    text-decoration: none;
    color: var(--t1);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.15s, border-color 0.15s;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .app-grid__item:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--b2);
    color: var(--t1);
  }
  .app-grid__name {
    font-size: 0.88rem;
    font-weight: 600;
  }
  .app-grid__platform {
    font-size: 0.72rem;
    color: var(--t3);
    font-family: var(--mono);
  }

  @media (max-width: 540px) {
    .app-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
