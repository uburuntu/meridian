---
/**
 * DocsSidebar — sidebar navigation for docs pages.
 * Builds navigation from content collection metadata.
 */
interface NavItem {
  title: string;
  slug: string;
  order: number;
}

interface NavSection {
  label: string;
  items: NavItem[];
}

interface Props {
  currentSlug?: string;
  sections: NavSection[];
}

const { currentSlug, sections } = Astro.props;
---

<aside class="sidebar" id="docs-sidebar">
  <div class="sidebar__search" id="search-container"></div>
  <nav aria-label="Documentation">
    {sections.map((section) => (
      <div class="sidebar__section">
        <div class="sidebar__label">{section.label}</div>
        <ul class="sidebar__list">
          {section.items.map((item) => (
            <li>
              <a
                href={`/docs/${item.slug}/`}
                class:list={['sidebar__link', { 'sidebar__link--active': currentSlug === item.slug }]}
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 68px;
    max-height: calc(100vh - 68px);
    overflow-y: auto;
    padding: 24px 0;
    width: 220px;
    flex-shrink: 0;
  }
  .sidebar__section {
    margin-bottom: 24px;
  }
  .sidebar__label {
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--t3);
    padding: 0 12px;
    margin-bottom: 6px;
  }
  .sidebar__list {
    list-style: none;
  }
  .sidebar__link {
    display: block;
    padding: 5px 12px;
    font-size: 0.82rem;
    color: var(--t2);
    text-decoration: none;
    border-radius: 4px;
    transition: color 0.1s, background 0.1s;
    line-height: 1.4;
  }
  .sidebar__link:hover {
    color: var(--t1);
    background: var(--s2);
  }
  .sidebar__link--active {
    color: var(--ac);
    background: var(--ac2);
  }

  @media (max-width: 860px) {
    .sidebar {
      display: none;
    }
  }

  /* Pagefind search overrides */
  .sidebar__search {
    padding: 0 8px 16px;
    border-bottom: 1px solid var(--b1);
    margin-bottom: 16px;
  }
  .sidebar__search :global(.pagefind-ui__search-input) {
    font-family: var(--body);
    font-size: 0.82rem;
    background: var(--bg);
    border: 1px solid var(--b1);
    border-radius: var(--r);
    color: var(--t1);
    padding: 8px 12px;
    width: 100%;
  }
  .sidebar__search :global(.pagefind-ui__search-input:focus) {
    border-color: var(--b2);
    outline: none;
  }
  .sidebar__search :global(.pagefind-ui__search-clear) {
    color: var(--t3);
  }
  .sidebar__search :global(.pagefind-ui__results-area) {
    font-size: 0.8rem;
  }
  .sidebar__search :global(.pagefind-ui__result-link) {
    color: var(--ac);
    font-size: 0.82rem;
  }
  .sidebar__search :global(.pagefind-ui__result-excerpt) {
    color: var(--t2);
    font-size: 0.75rem;
  }
  .sidebar__search :global(.pagefind-ui__message) {
    color: var(--t3);
    font-size: 0.75rem;
  }
  .sidebar__search :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-primary: var(--ac);
    --pagefind-ui-text: var(--t1);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--b1);
    --pagefind-ui-tag: var(--s2);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: var(--body);
  }
</style>

<script is:inline>
  (async function() {
    var container = document.getElementById('search-container');
    if (!container) return;

    try {
      var pagefind = await import('/pagefind/pagefind-ui.js');
      new pagefind.PagefindUI({
        element: '#search-container',
        showSubResults: true,
        showImages: false,
      });
    } catch (e) {
      container.innerHTML = '<input type="search" placeholder="Search docs..." style="font-family:var(--body);font-size:0.82rem;background:var(--bg);border:1px solid var(--b1);border-radius:6px;color:var(--t1);padding:8px 12px;width:100%;opacity:0.5" disabled title="Search available in production build" />';
    }
  })();
</script>
