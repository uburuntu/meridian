---
/**
 * DocsSidebar — sidebar navigation for docs pages.
 * Builds navigation from content collection metadata.
 */
interface NavItem {
  title: string;
  slug: string;
  order: number;
}

interface NavSection {
  label: string;
  items: NavItem[];
}

interface Props {
  currentSlug?: string;
  sections: NavSection[];
}

const { currentSlug, sections } = Astro.props;
---

<aside class="sidebar" id="docs-sidebar">
  <nav aria-label="Documentation">
    {sections.map((section) => (
      <div class="sidebar__section">
        <div class="sidebar__label">{section.label}</div>
        <ul class="sidebar__list">
          {section.items.map((item) => (
            <li>
              <a
                href={`/docs/${item.slug}/`}
                class:list={['sidebar__link', { 'sidebar__link--active': currentSlug === item.slug }]}
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 68px;
    max-height: calc(100vh - 68px);
    overflow-y: auto;
    padding: 24px 0;
    width: 220px;
    flex-shrink: 0;
  }
  .sidebar__section {
    margin-bottom: 24px;
  }
  .sidebar__label {
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--t3);
    padding: 0 12px;
    margin-bottom: 6px;
  }
  .sidebar__list {
    list-style: none;
  }
  .sidebar__link {
    display: block;
    padding: 5px 12px;
    font-size: 0.82rem;
    color: var(--t2);
    text-decoration: none;
    border-radius: 4px;
    transition: color 0.1s, background 0.1s;
    line-height: 1.4;
  }
  .sidebar__link:hover {
    color: var(--t1);
    background: var(--s2);
  }
  .sidebar__link--active {
    color: var(--ac);
    background: var(--ac2);
  }

  @media (max-width: 860px) {
    .sidebar {
      display: none;
    }
  }
</style>
