---
/**
 * Nav — warm editorial navigation.
 * Clean, understated. Logo + links. No glass morphism.
 */
---

<nav class="nav" aria-label="Main navigation">
  <div class="nav__inner">
    <a href="/" class="nav__logo" aria-label="Meridian home">
      <img src="/img/favicon-32.png" alt="" width="22" height="22" />
      <span>Meridian</span>
    </a>

    <div class="nav__links">
      <a href="/docs/" data-astro-prefetch>Docs</a>
      <a href="/demo/" data-astro-prefetch>Demo</a>
      <a href="/ping/" data-astro-prefetch>Ping</a>
      <a href="https://github.com/uburuntu/meridian" target="_blank" rel="noopener" class="nav__gh" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0 24px;
    background: var(--bg);
    border-bottom: 1px solid var(--b1);
  }
  .nav__inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .nav__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--heading);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--t1);
    text-decoration: none;
  }
  .nav__logo:hover {
    color: var(--ac);
  }
  .nav__logo img {
    border-radius: 4px;
  }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav__links a {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--t2);
    text-decoration: none;
    transition: color 0.12s;
  }
  .nav__links a:hover {
    color: var(--t1);
  }
  .nav__gh {
    display: flex;
    color: var(--t3);
  }
  .nav__gh:hover {
    color: var(--t1);
  }

  @media (max-width: 480px) {
    .nav__links { gap: 18px; }
    .nav__links a { font-size: 0.84rem; }
  }
</style>
