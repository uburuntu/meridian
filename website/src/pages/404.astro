---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — Meridian">
  <main id="main">
    <section class="not-found">
      <div class="container">
        <h1>404</h1>
        <p>This page doesn't exist.</p>
        <div class="not-found__links">
          <a href="/" class="not-found__btn">Home</a>
          <a href="/docs/en/getting-started/" class="not-found__btn not-found__btn--secondary">Docs</a>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .not-found {
    padding: calc(56px + 80px) 0 120px;
    text-align: center;
  }
  .not-found h1 {
    font-size: 6rem;
    color: var(--b2);
    line-height: 1;
    margin-bottom: 8px;
  }
  .not-found p {
    color: var(--t3);
    font-size: 1.1rem;
    margin-bottom: 32px;
  }
  .not-found__links {
    display: flex;
    gap: 12px;
    justify-content: center;
  }
  .not-found__btn {
    display: inline-flex;
    padding: 10px 24px;
    border-radius: var(--r);
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    background: var(--ac);
    color: #fff;
    transition: background 0.15s;
  }
  .not-found__btn:hover {
    background: var(--ac-hover);
    color: #fff;
  }
  .not-found__btn--secondary {
    background: var(--s1);
    color: var(--t1);
    border: 1px solid var(--b1);
  }
  .not-found__btn--secondary:hover {
    background: var(--s2);
    color: var(--t1);
  }
</style>
