---
/**
 * Demo route — Astro's dev server doesn't resolve index.html for public/ dirs,
 * so this page serves public/demo/index.html at the /demo/ path.
 * In production, CI writes demo files directly into dist/demo/.
 */
import fs from 'node:fs';

const demoPath = new URL('../../public/demo/index.html', import.meta.url);
const html = fs.existsSync(demoPath) ? fs.readFileSync(demoPath, 'utf8') : '';
---
<Fragment set:html={html} />
