---
/**
 * Locale-specific landing pages (/ru/, /fa/, /zh/).
 *
 * Renders the same content as the English index.astro but with translations
 * baked into the HTML at build time. This makes translated content indexable
 * by search engines without requiring client-side JavaScript.
 *
 * English stays at / (index.astro). Client-side data-t swapping still works
 * as a fallback on all pages.
 */
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import Timeline from '../../components/Timeline.astro';
import AppGrid from '../../components/AppGrid.astro';
import Accordion from '../../components/Accordion.astro';
import Callout from '../../components/Callout.astro';
import CommandBuilder from '../../components/CommandBuilder.astro';
import { createT } from '../../i18n/t';

export function getStaticPaths() {
  return [
    { params: { locale: 'ru' } },
    { params: { locale: 'fa' } },
    { params: { locale: 'zh' } },
  ];
}

const locale = Astro.params.locale!;
const t = createT(locale);
const dir = locale === 'fa' ? 'rtl' : 'ltr';

const detailSteps = [
  { title: t('step.1.title', 'Installs Docker'), text: t('step.1.text', ' and deploys <strong>Xray</strong> managed by the <strong>Remnawave</strong> panel') },
  { title: t('step.2.title', 'Generates x25519 keypair'), text: t('step.2.text', ' — unique encryption keys for Reality authentication') },
  { title: t('step.3.title', 'Hardens the server'), text: t('step.3.text', ' — UFW firewall (ports 22 + 443 only), SSH key-only auth, <strong>BBR</strong> congestion control') },
  { title: t('step.4.title', 'Configures VLESS+Reality'), text: t('step.4.text', ' on port 443 — impersonates a real TLS server') },
  { title: t('step.5.title', 'Enables XHTTP transport'), text: t('step.5.text', ' — additional stealth routed through nginx, no extra port') },
  { title: t('step.6.title', 'Outputs QR codes'), text: t('step.6.text', ' and generates an HTML connection page with setup instructions') },
];

const hreflangLinks = [
  { lang: 'en', href: 'https://getmeridian.org/' },
  { lang: 'ru', href: 'https://getmeridian.org/ru/' },
  { lang: 'fa', href: 'https://getmeridian.org/fa/' },
  { lang: 'zh-Hans', href: 'https://getmeridian.org/zh/' },
  { lang: 'x-default', href: 'https://getmeridian.org/' },
];
---

<Base title={t('page.title', 'Meridian — Censorship-Resistant Proxy, Deployed Right')}>
  <Fragment slot="head">
    {hreflangLinks.map((l) => (
      <link rel="alternate" hreflang={l.lang} href={l.href} />
    ))}
  </Fragment>

  <main id="main" dir={dir}>
    <Hero locale={locale} />

    <!-- TRUST BAR -->
    <section class="trust-bar">
      <div class="container">
        <div class="trust-items">
          <div class="trust-item">
            <span class="trust-value" data-t="trust.mit">{t('trust.mit', 'MIT Licensed')}</span>
          </div>
          <div class="trust-item">
            <span class="trust-value" data-t="trust.languages">{t('trust.languages', '4 Languages')}</span>
          </div>
          <div class="trust-item">
            <span class="trust-value" data-t="trust.oss">{t('trust.oss', '100% Open Source')}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="setup" class="reveal">
      <div class="container">
        <div class="section-label" data-t="setup.label">{t('setup.label', 'How it works')}</div>
        <h2 data-t="setup.title">{t('setup.title', 'Three steps to secure internet')}</h2>
        <p class="section-desc" data-t="setup.desc">{t('setup.desc', 'You need a VPS (any $5/month server) and a terminal on your laptop. Meridian handles everything else.')}</p>

        <div class="setup-grid">
          <div class="setup-main">
            <CodeBlock code="curl -sSf https://getmeridian.org/install.sh | bash" label={t('setup.step1.label', 'Step 1 — Install')} />

            <div class="step-separator">
              <span data-t="setup.then">{t('setup.then', 'then')}</span>
            </div>

            <CodeBlock code="meridian deploy" label={t('setup.step2.label', 'Step 2 — Deploy')} />

            <p class="setup-hint" data-t="setup.hint" set:html={t('setup.hint', `The wizard asks for your server IP and handles the rest. Or pass flags directly — see the <a href="/docs/${locale}/cli-reference/" data-astro-prefetch>CLI reference</a>.`)} />
          </div>

          <div class="setup-aside">
            <img src="/img/deploy-terminal.svg" alt="Meridian deploy output" class="deploy-terminal" loading="lazy" width="720" height="780" />
            <h3 data-t="setup.details">{t('setup.details', 'What happens behind the scenes')}</h3>
            <Timeline steps={detailSteps} />
            <Callout variant="tip" icon="⏱" data-t="setup.idempotent">
              {t('setup.idempotent', 'Safe to re-run anytime. Fully idempotent — credentials preserved, settings updated in place.')}
            </Callout>
          </div>
        </div>
      </div>
    </section>

    <hr class="hr" />

    <!-- COMMAND BUILDER -->
    <section id="builder-section" class="reveal">
      <div class="container">
        <div class="section-label" data-t="builder.label">{t('builder.label', 'Command builder')}</div>
        <h2 data-t="builder.title">{t('builder.title', 'Build your command')}</h2>
        <p class="section-desc" data-t="builder.desc">{t('builder.desc', 'Configure flags interactively and copy the full command. Supports all Meridian CLI operations.')}</p>

        <CommandBuilder />
      </div>
    </section>

    <hr class="hr" />

    <!-- WHY IT WORKS -->
    <section id="technology" class="reveal">
      <div class="container">
        <div class="section-label" data-t="tech.label">{t('tech.label', 'Technology')}</div>
        <h2 data-t="tech.title">{t('tech.title', 'Why censors can\'t detect it')}</h2>
        <p class="section-desc" data-t="tech.desc">{t('tech.desc', 'Traditional VPNs have distinctive traffic signatures. VLESS+Reality is indistinguishable from normal web browsing.')}</p>

        <div class="tech-grid">
          <Accordion title={t('tech.dpi', 'Deep Packet Inspection (DPI)')} open>
            <p>
              DPI analyzes traffic patterns to identify proxy protocols. VPNs like
              OpenVPN and WireGuard have distinctive packet signatures that are trivial to block.
            </p>
            <p>
              <strong>VLESS+Reality</strong> produces traffic byte-for-byte identical to a normal
              HTTPS connection. No headers, no patterns, no packet sizes that distinguish it from
              regular web browsing.
            </p>
          </Accordion>

          <Accordion title={t('tech.probe', 'Active probing')}>
            <p>
              Censors connect to suspicious servers and try to fingerprint them. If a server
              responds differently than the website it claims to be, it gets blocked.
            </p>
            <p>
              <strong>Reality</strong> uses the TLS certificate from a real website (e.g., microsoft.com).
              When a probe connects, your server completes the handshake using Microsoft's actual
              certificate. The probe sees a legitimate server. Only clients with your private key
              get the proxy tunnel.
            </p>
          </Accordion>

          <Accordion title={t('tech.fp', 'TLS fingerprinting')}>
            <p>
              Every TLS client sends a unique "Client Hello" fingerprint. Censors flag connections
              where the fingerprint doesn't match the claimed application.
            </p>
            <p>
              Meridian uses <strong>uTLS</strong> to impersonate Chrome's exact TLS fingerprint —
              the same one used by billions of devices. Your traffic is indistinguishable from
              someone browsing the web with Chrome.
            </p>
          </Accordion>
        </div>
      </div>
    </section>

    <hr class="hr" />

    <!-- CONNECT -->
    <section id="connect" class="reveal">
      <div class="container">
        <div class="section-label" data-t="connect.label">{t('connect.label', 'Connect')}</div>
        <h2 data-t="connect.title">{t('connect.title', 'Scan and go')}</h2>
        <p class="section-desc" data-t="connect.desc">{t('connect.desc', 'After deploying, you get a connection page with QR codes. Send it to whoever needs it — they tap once and connect.')}</p>

        <AppGrid />

        <Callout variant="warning" data-t="connect.clock">
          {t('connect.clock', 'Device clock must be accurate within 30 seconds. Enable automatic date/time in your device settings.')}
        </Callout>
      </div>
    </section>

    <hr class="hr" />

    <!-- ARCHITECTURE -->
    <section id="architecture" class="reveal">
      <div class="container">
        <div class="section-label" data-t="arch.label">{t('arch.label', 'Architecture')}</div>
        <h2 data-t="arch.title">{t('arch.title', 'Under the hood')}</h2>

        <div class="arch-img">
          <img
            src="/img/architecture.svg"
            alt="Meridian architecture — nginx SNI routing and TLS, Xray Reality"
            loading="lazy"
            width="1200"
            height="780"
          />
        </div>

        <div class="arch-grid">
          <Accordion title={t('arch.standalone', 'Standalone mode (no domain)')} open>
            <p>
              <strong>nginx</strong> sits on port 443 and routes traffic by TLS SNI using its stream module.
              Reality connections route to <strong>Xray</strong>, while nginx's http module
              handles everything else — serving connection pages over HTTPS with a Let's Encrypt
              IP certificate (via acme.sh). XHTTP transport runs through nginx via path-based routing — no
              extra port exposed.
            </p>
            <p>
              The Remnawave admin panel is reverse-proxied by nginx on a secret path —
              accessible via HTTPS, no SSH tunnel needed.
            </p>
          </Accordion>

          <Accordion title={t('arch.domain', 'Domain mode (CDN fallback)')}>
            <p>Adds three components on top of standalone:</p>
            <p>
              <strong>nginx stream</strong> inspects TLS SNI without terminating encryption.
              <strong>nginx http</strong> terminates TLS with Let's Encrypt certificates managed by acme.sh.
              <strong>VLESS+WSS</strong> provides a CDN fallback through Cloudflare — works even
              if your server's IP is blocked.
            </p>
          </Accordion>

          <Accordion title={t('arch.relay', 'Relay mode (domestic entry point)')}>
            <p>
              A lightweight <strong>Realm</strong> TCP forwarder on a domestic server relays
              port 443 to your exit server abroad. All protocols work through the relay
              with end-to-end encryption — the relay never sees your traffic.
            </p>
            <p>
              Deploy with <code>meridian relay deploy RELAY_IP</code>. Client connection
              pages are automatically regenerated with relay routes.
            </p>
          </Accordion>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="cta" class="reveal cta-section">
      <div class="container cta-content">
        <h2 data-t="cta.title">{t('cta.title', 'Ready to get started?')}</h2>
        <p class="section-desc cta-desc" data-t="cta.desc">{t('cta.desc', 'Install Meridian, deploy to your server, and share access with the people who need it. The whole process takes about five minutes.')}</p>
        <div class="hero__actions cta-actions">
          <a href="#setup" class="hero__btn hero__btn--primary" data-t="cta.install">{t('cta.install', 'Install Meridian')}</a>
          <a href={`/docs/${locale}/getting-started/`} class="hero__btn hero__btn--secondary" data-astro-prefetch data-t="hero.docs">
            {t('hero.docs', 'Read the docs')}
          </a>
        </div>
      </div>
    </section>
  </main>
</Base>

<!-- Scroll reveal animations -->
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' },
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Setup section — two-column on desktop */
  .setup-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .setup-grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
  }

  .deploy-terminal {
    width: 100%;
    max-width: 480px;
    height: auto;
    border-radius: var(--r2);
    margin-bottom: 24px;
  }

  .setup-aside h3 {
    font-size: 0.95rem;
    margin-bottom: 16px;
    color: var(--t2);
    font-family: var(--body);
    font-weight: 600;
  }

  .step-separator {
    text-align: center;
    color: var(--t3);
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 16px 0;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .step-separator::before,
  .step-separator::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--b1);
  }

  .setup-hint {
    font-size: 0.85rem;
    color: var(--t3);
    margin-top: 16px;
    line-height: 1.6;
  }
  .setup-hint :global(a) {
    color: var(--ac);
  }

  /* Architecture image */
  .arch-img {
    border-radius: var(--r2);
    overflow: hidden;
    border: 1px solid var(--b1);
    box-shadow: var(--shadow-md);
    margin-bottom: 28px;
    max-width: 720px;
  }
  .arch-img img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Trust bar */
  .trust-bar {
    padding: 0 0 24px;
  }
  .trust-items {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .trust-item {
    text-align: center;
  }
  .trust-value {
    font-family: var(--mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--t3);
  }

  /* CTA */
  .cta-section {
    text-align: center;
    padding-top: 48px;
  }
  .cta-content {
    max-width: 560px;
    margin-inline: auto;
  }
  .cta-desc {
    margin-inline: auto;
  }
  .cta-actions {
    justify-content: center;
  }

  /* Accessibility: respect motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
