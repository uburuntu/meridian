---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function slugifyCategory(text: string) {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
---

<Base title="Blog — Meridian" description="Articles on censorship circumvention, proxy architecture, and internet freedom.">
  <main id="main" class="blog-index">
    <header class="blog-index__header">
      <h1>Blog</h1>
      <p>How censorship circumvention works, why it matters, and how to stay connected.</p>
    </header>
    <div class="blog-grid">
      {posts.map((post) => {
        const formatted = post.data.date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <div class="blog-card">
            <div class="blog-card__top">
              <a href={`/blog/category/${slugifyCategory(post.data.category)}/`} class="blog-card__category">{post.data.category}</a>
              <span class="blog-card__time">{post.data.readingTime} min</span>
            </div>
            <h2 class="blog-card__title">
              <a href={`/blog/${post.id}/`} data-astro-prefetch>{post.data.title}</a>
            </h2>
            <p class="blog-card__desc">{post.data.description}</p>
            <div class="blog-card__footer">
              <time class="blog-card__date" datetime={post.data.date.toISOString().slice(0, 10)}>
                {formatted}
              </time>
              <div class="blog-card__tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <a href={`/blog/tag/${tag}/`} class="blog-card__tag">#{tag}</a>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </main>
</Base>

<style>
  .blog-index {
    max-width: 800px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }
  .blog-index__header {
    margin-bottom: 40px;
  }
  .blog-index__header h1 {
    margin-bottom: 8px;
  }
  .blog-index__header p {
    color: var(--t3);
    font-size: 0.92rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    padding: 20px;
    border: 1px solid var(--b1);
    border-radius: var(--r);
    position: relative;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .blog-card:hover {
    border-color: var(--b2);
    box-shadow: var(--shadow-sm);
  }

  .blog-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .blog-card__category {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 2px 8px;
    background: var(--ac3);
    color: var(--ac);
    border-radius: 4px;
    position: relative;
    z-index: 1;
  }
  .blog-card__time {
    font-size: 0.76rem;
    color: var(--t3);
  }

  .blog-card__title {
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.35;
    color: var(--t1);
    margin-bottom: 8px;
  }
  .blog-card__title a {
    text-decoration: none;
    color: inherit;
  }
  /* Stretched link: makes the entire card clickable via the title link */
  .blog-card__title a::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .blog-card__desc {
    font-size: 0.84rem;
    line-height: 1.55;
    color: var(--t2);
    flex: 1;
    margin-bottom: 12px;
  }
  .blog-card__date {
    font-size: 0.76rem;
    color: var(--t3);
  }

  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .blog-card__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .blog-card__tags a {
    font-size: 0.68rem;
    color: var(--t3);
    text-decoration: none;
    position: relative;
    z-index: 1;
    transition: color 0.12s;
  }
  .blog-card__tags a:hover {
    color: var(--ac);
  }

  .blog-card__category {
    text-decoration: none;
    transition: opacity 0.12s;
  }
</style>
