---
/**
 * Dynamic docs route — renders content collection entries as pages.
 * Locale-aware: filters sidebar to show only docs from the same language.
 * Adds locale switcher and markdown alternate link.
 */
import { getCollection, render } from 'astro:content';
import Docs from '../../layouts/Docs.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Detect locale from slug: "en/getting-started" → "en"
const locale = entry.id.split('/')[0];
const pageSlug = entry.id.split('/').slice(1).join('/');

// Build sidebar from docs in the same locale only
const allDocs = await getCollection('docs');
const localeDocs = allDocs.filter((doc) => doc.id.startsWith(locale + '/'));

const sectionOrder = ['guides', 'reference'];
const sectionLabels: Record<string, Record<string, string>> = {
  en: { guides: 'Guides', reference: 'Reference' },
  ru: { guides: 'Руководства', reference: 'Справочник' },
  fa: { guides: 'راهنماها', reference: 'مرجع' },
  zh: { guides: '指南', reference: '参考' },
};
const labels = sectionLabels[locale] ?? sectionLabels.en;

const sections = sectionOrder
  .map((sectionKey) => {
    const items = localeDocs
      .filter((doc) => doc.data.section === sectionKey)
      .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
      .map((doc) => ({
        title: doc.data.title,
        slug: doc.id,
        order: doc.data.order ?? 99,
      }));

    return {
      label: labels[sectionKey] ?? sectionKey,
      items,
    };
  })
  .filter((s) => s.items.length > 0);

// Find available translations for locale switcher
const localeNames: Record<string, string> = { en: 'EN', ru: 'RU', fa: 'فا', zh: '中文' };
const availableLocales = [...new Set(allDocs.filter((doc) => {
  const docPage = doc.id.split('/').slice(1).join('/');
  return docPage === pageSlug;
}).map((doc) => doc.id.split('/')[0]))];

const mdPath = `/md/${entry.id}`;
---

<Docs
  title={entry.data.title}
  description={entry.data.description}
  headings={headings}
  sections={sections}
  currentSlug={entry.id}
  locale={locale}
  availableLocales={availableLocales.map((l) => ({ code: l, label: localeNames[l] ?? l, href: `/docs/${l}/${pageSlug}/` }))}
  mdPath={mdPath}
>
  <Content />
</Docs>
