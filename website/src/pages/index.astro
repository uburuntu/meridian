---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Timeline from '../components/Timeline.astro';
import AppGrid from '../components/AppGrid.astro';
import Accordion from '../components/Accordion.astro';
import Callout from '../components/Callout.astro';
import CommandBuilder from '../components/CommandBuilder.astro';

const detailSteps = [
  { title: 'Installs Docker', text: ' and deploys <strong>Xray</strong> via the <strong>3x-ui</strong> management panel', titleKey: 'step.1.title', textKey: 'step.1.text' },
  { title: 'Generates x25519 keypair', text: ' — unique encryption keys for Reality authentication', titleKey: 'step.2.title', textKey: 'step.2.text' },
  { title: 'Hardens the server', text: ' — UFW firewall (ports 22 + 443 only), SSH key-only auth, <strong>BBR</strong> congestion control', titleKey: 'step.3.title', textKey: 'step.3.text' },
  { title: 'Configures VLESS+Reality', text: ' on port 443 — impersonates a real TLS server', titleKey: 'step.4.title', textKey: 'step.4.text' },
  { title: 'Enables XHTTP transport', text: ' — additional stealth routed through Caddy, no extra port', titleKey: 'step.5.title', textKey: 'step.5.text' },
  { title: 'Outputs QR codes', text: ' and generates an HTML connection page with setup instructions', titleKey: 'step.6.title', textKey: 'step.6.text' },
];
---

<Base title="Meridian — Censorship-Resistant Proxy">
  <main id="main">
    <Hero />

    <!-- HOW IT WORKS (simple) -->
    <section id="setup" class="reveal">
      <div class="container">
        <div class="section-label" data-t="setup.label">How it works</div>
        <h2 data-t="setup.title">Three steps to secure internet</h2>
        <p class="section-desc" data-t="setup.desc">
          You need a VPS (any $5/month server) and a terminal on your laptop. Meridian handles everything else.
        </p>

        <div class="setup-grid">
          <div class="setup-main">
            <CodeBlock code="curl -sSf https://getmeridian.org/install.sh | bash" label="Step 1 — Install" />

            <div class="step-separator">
              <span>then</span>
            </div>

            <CodeBlock code="meridian deploy" label="Step 2 — Deploy" />

            <p class="setup-hint" data-t="setup.hint">
              The wizard asks for your server IP and handles the rest. Or pass flags directly —
              see the <a href="/docs/en/cli-reference/" data-astro-prefetch>CLI reference</a>.
            </p>
          </div>

          <div class="setup-aside">
            <h3 data-t="setup.details">What happens behind the scenes</h3>
            <Timeline steps={detailSteps} />
            <Callout variant="tip" icon="⏱" data-t="setup.idempotent">
              Safe to re-run anytime. Fully idempotent — credentials preserved, settings updated in place.
            </Callout>
          </div>
        </div>
      </div>
    </section>

    <hr class="hr" />

    <!-- COMMAND BUILDER -->
    <section id="builder-section" class="reveal">
      <div class="container">
        <div class="section-label" data-t="builder.label">Command builder</div>
        <h2 data-t="builder.title">Build your command</h2>
        <p class="section-desc" data-t="builder.desc">
          Configure flags interactively and copy the full command. Supports all Meridian CLI operations.
        </p>

        <CommandBuilder />
      </div>
    </section>

    <hr class="hr" />

    <!-- WHY IT WORKS -->
    <section id="technology" class="reveal">
      <div class="container">
        <div class="section-label" data-t="tech.label">Technology</div>
        <h2 data-t="tech.title">Why censors can't detect it</h2>
        <p class="section-desc" data-t="tech.desc">
          Traditional VPNs have distinctive traffic signatures. VLESS+Reality is
          indistinguishable from normal web browsing.
        </p>

        <div class="tech-grid">
          <Accordion title="Deep Packet Inspection (DPI)" titleKey="tech.dpi" open>
            <p>
              DPI analyzes traffic patterns to identify proxy protocols. VPNs like
              OpenVPN and WireGuard have distinctive packet signatures that are trivial to block.
            </p>
            <p>
              <strong>VLESS+Reality</strong> produces traffic byte-for-byte identical to a normal
              HTTPS connection. No headers, no patterns, no packet sizes that distinguish it from
              regular web browsing.
            </p>
          </Accordion>

          <Accordion title="Active probing" titleKey="tech.probe">
            <p>
              Censors connect to suspicious servers and try to fingerprint them. If a server
              responds differently than the website it claims to be, it gets blocked.
            </p>
            <p>
              <strong>Reality</strong> uses the TLS certificate from a real website (e.g., microsoft.com).
              When a probe connects, your server completes the handshake using Microsoft's actual
              certificate. The probe sees a legitimate server. Only clients with your private key
              get the proxy tunnel.
            </p>
          </Accordion>

          <Accordion title="TLS fingerprinting" titleKey="tech.fp">
            <p>
              Every TLS client sends a unique "Client Hello" fingerprint. Censors flag connections
              where the fingerprint doesn't match the claimed application.
            </p>
            <p>
              Meridian uses <strong>uTLS</strong> to impersonate Chrome's exact TLS fingerprint —
              the same one used by billions of devices. Your traffic is indistinguishable from
              someone browsing the web with Chrome.
            </p>
          </Accordion>
        </div>
      </div>
    </section>

    <hr class="hr" />

    <!-- CONNECT -->
    <section id="connect" class="reveal">
      <div class="container">
        <div class="section-label" data-t="connect.label">Connect</div>
        <h2 data-t="connect.title">Scan and go</h2>
        <p class="section-desc" data-t="connect.desc">
          After deploying, you get a connection page with QR codes. Send it to
          whoever needs it — they tap once and connect.
        </p>

        <AppGrid />

        <Callout variant="warning" data-t="connect.clock">
          Device clock must be accurate within 30 seconds. Enable automatic date/time
          in your device settings.
        </Callout>
      </div>
    </section>

    <hr class="hr" />

    <!-- ARCHITECTURE -->
    <section id="architecture" class="reveal">
      <div class="container">
        <div class="section-label" data-t="arch.label">Architecture</div>
        <h2 data-t="arch.title">Under the hood</h2>

        <div class="arch-img">
          <img
            src="/img/architecture.png"
            alt="Meridian architecture — HAProxy SNI routing, Caddy TLS, Xray Reality"
            loading="lazy"
            width="1200"
            height="669"
          />
        </div>

        <div class="arch-grid">
          <Accordion title="Standalone mode (no domain)" titleKey="arch.standalone" open>
            <p>
              <strong>HAProxy</strong> sits on port 443 and routes traffic by TLS SNI.
              Reality connections route to <strong>Xray</strong>, while <strong>Caddy</strong>
              handles everything else — serving connection pages over HTTPS with a Let's Encrypt
              IP certificate. XHTTP transport runs through Caddy via path-based routing — no
              extra port exposed.
            </p>
            <p>
              The 3x-ui panel is reverse-proxied by Caddy on a secret path — accessible
              via HTTPS, no SSH tunnel needed.
            </p>
          </Accordion>

          <Accordion title="Domain mode (CDN fallback)" titleKey="arch.domain">
            <p>Adds three components on top of standalone:</p>
            <p>
              <strong>HAProxy</strong> inspects TLS SNI without terminating encryption.
              <strong>Caddy</strong> terminates TLS with automatic Let's Encrypt certificates.
              <strong>VLESS+WSS</strong> provides a CDN fallback through Cloudflare — works even
              if your server's IP is blocked.
            </p>
          </Accordion>
        </div>
      </div>
    </section>

    <hr class="hr" />

    <!-- REFERENCE -->
    <section id="reference" class="reveal">
      <div class="container">
        <div class="section-label" data-t="ref.label">Reference</div>
        <h2 data-t="ref.title">Configuration & operations</h2>

        <Accordion title="Customization" titleKey="ref.customization">
          <p>All settings are passed as CLI flags to <code>meridian deploy</code>:</p>
          <div class="ref-table-wrap">
            <table class="ref-table">
              <thead>
                <tr><th>Flag</th><th>Default</th><th>Description</th></tr>
              </thead>
              <tbody>
                <tr><td>--sni HOST</td><td>www.microsoft.com</td><td>Site that Reality impersonates</td></tr>
                <tr><td>--domain DOMAIN</td><td>(none)</td><td>Enable domain mode with CDN fallback</td></tr>
                <tr><td>--xhttp / --no-xhttp</td><td>enabled</td><td>XHTTP transport (through port 443)</td></tr>
                <tr><td>--email EMAIL</td><td>(none)</td><td>Email for TLS certificates</td></tr>
                <tr><td>--name NAME</td><td>default</td><td>Name for the first client</td></tr>
                <tr><td>--user USER</td><td>root</td><td>SSH user (non-root gets sudo)</td></tr>
                <tr><td>--yes</td><td></td><td>Skip confirmation prompts</td></tr>
              </tbody>
            </table>
          </div>
          <p>
            For optimal stealth, use <code>meridian scan</code> or
            <a href="https://github.com/XTLS/RealiTLScanner">RealiTLScanner</a>
            to find an SNI target near your server.
          </p>
        </Accordion>

        <Accordion title="Cloudflare CDN setup" titleKey="ref.cloudflare">
          <p><strong>Follow this order</strong> to avoid TLS certificate issues:</p>
          <p>
            1. Add domain in Cloudflare, create A record to server IP<br />
            2. Keep cloud icon <strong>grey</strong> ("DNS only")<br />
            3. Run <code>meridian deploy</code> — Caddy gets the cert<br />
            4. Switch to <strong>orange cloud</strong> (Proxied)<br />
            5. SSL/TLS → <strong>Full (Strict)</strong>, enable WebSockets
          </p>
        </Accordion>

        <Accordion title="Client management" titleKey="ref.clients">
          <p>Share access with friends — each gets their own key:</p>
          <CodeBlock code="meridian client add alice" />
          <p>List all clients:</p>
          <CodeBlock code="meridian client list" />
          <p>Revoke access:</p>
          <CodeBlock code="meridian client remove alice" />
        </Accordion>

        <Accordion title="Troubleshooting" titleKey="ref.troubleshoot">
          <p><strong>Not connecting?</strong> Test reachability from your device:</p>
          <CodeBlock code="meridian test" />
          <p>
            Or use the <a href="/ping/" data-astro-prefetch>web-based ping tool</a> — no install needed.
          </p>
          <p><strong>Connection fails immediately:</strong> Check device clock (±30 seconds).</p>
          <p><strong>Was working, now stopped:</strong> IP may be blocked. Use CDN fallback or deploy a new server.</p>
          <p>AI-powered diagnostics:</p>
          <CodeBlock code="meridian doctor --ai" />
        </Accordion>

        <Accordion title="Update & maintenance" titleKey="ref.update">
          <CodeBlock code={`ssh root@YOUR_SERVER\ncd /opt/3x-ui && docker compose pull && docker compose up -d`} />
          <p>Or re-run <code>meridian deploy</code> — safe to repeat anytime.</p>
        </Accordion>

        <Accordion title="Uninstall" titleKey="ref.uninstall">
          <CodeBlock code="meridian teardown" />
          <p>Removes the proxy container, configs, and firewall rules. Docker and system packages are kept.</p>
        </Accordion>

        <Accordion title="Security notes" titleKey="ref.security">
          <p>
            Credentials at <code>/etc/meridian/</code> (server) and <code>~/.meridian/credentials/</code> (local).
            Panel reverse-proxied on a secret HTTPS path. SSH password auth disabled. UFW allows only 22, 80, 443.
            Docker image pinned. All secrets redacted from output.
          </p>
        </Accordion>
      </div>
    </section>
  </main>
</Base>

<!-- Scroll reveal animations -->
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' },
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Setup section — two-column on desktop */
  .setup-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .setup-grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
  }

  .setup-aside h3 {
    font-size: 0.95rem;
    margin-bottom: 16px;
    color: var(--t2);
    font-family: var(--body);
    font-weight: 600;
  }

  .step-separator {
    text-align: center;
    color: var(--t3);
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 16px 0;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .step-separator::before,
  .step-separator::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--b1);
  }

  .setup-hint {
    font-size: 0.85rem;
    color: var(--t3);
    margin-top: 16px;
    line-height: 1.6;
  }
  .setup-hint a {
    color: var(--ac);
  }

  /* Architecture image */
  .arch-img {
    border-radius: var(--r2);
    overflow: hidden;
    border: 1px solid var(--b1);
    box-shadow: var(--shadow-md);
    margin-bottom: 28px;
    max-width: 720px;
  }
  .arch-img img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Reference table */
  .ref-table-wrap {
    overflow-x: auto;
    margin: 12px 0;
  }
  .ref-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  .ref-table th {
    text-align: left;
    color: var(--t3);
    font-weight: 600;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 8px 14px;
    border-bottom: 2px solid var(--b1);
  }
  .ref-table td {
    padding: 8px 14px;
    border-bottom: 1px solid var(--b1);
    color: var(--t2);
    vertical-align: top;
  }
  .ref-table td:first-child {
    color: var(--t1);
    font-family: var(--mono);
    font-size: 0.8rem;
    white-space: nowrap;
  }
  .ref-table tr:last-child td {
    border-bottom: none;
  }

  [dir="rtl"] .ref-table th { text-align: right; }
</style>
