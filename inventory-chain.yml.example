# =============================================================================
# Chain Mode Inventory (Exit + Relay)
# =============================================================================
# Copy this file to inventory-chain.yml and fill in your server IPs.
#
# Usage:
#   cp inventory-chain.yml.example inventory-chain.yml
#   # Edit the file with your IPs
#   ansible-playbook -i inventory-chain.yml playbook-chain.yml
#
# The exit node (Germany) is configured FIRST, then its credentials are
# automatically passed to the relay node (Russia).
# =============================================================================

all:
  children:
    exit:
      hosts:
        exit_server:
          ansible_host: "EXIT_SERVER_IP"    # <-- German VPS IP
          ansible_user: root
          # domain: "example.com"           # <-- Optional: enables CDN fallback
          # email: "you@example.com"        # <-- Optional: for Let's Encrypt notifications

    relay:
      hosts:
        relay_server:
          ansible_host: "RELAY_SERVER_IP"   # <-- Russian VPS IP (must be whitelisted)
          ansible_user: root
          exit_node: "exit_server"          # <-- Must match the exit host name above
