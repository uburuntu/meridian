#!/usr/bin/env bash
# =============================================================================
# Meridian CLI — Censorship-resistant proxy server management
#
# Install:   curl -sSf https://meridian.msu.rocks/install.sh | bash
# Usage:     meridian setup 1.2.3.4
#            meridian client add alice
#            meridian help
#
# https://github.com/uburuntu/meridian
# =============================================================================
set -euo pipefail

MERIDIAN_VERSION="1.2.4"

# --- Directories & paths ---
MERIDIAN_HOME="${MERIDIAN_HOME:-$HOME/.meridian}"
CREDS_BASE="$MERIDIAN_HOME/credentials"
PLAYBOOKS_DIR="$MERIDIAN_HOME/playbooks"
CACHE_DIR="$MERIDIAN_HOME/cache"
SERVERS_FILE="$MERIDIAN_HOME/servers"
SERVER_CREDS_DIR="/etc/meridian"

# --- URLs ---
TARBALL_URL="https://github.com/uburuntu/meridian/archive/refs/tags/v${MERIDIAN_VERSION}.tar.gz"
TARBALL_FALLBACK_URL="https://github.com/uburuntu/meridian/archive/refs/heads/main.tar.gz"
VERSION_URL="https://meridian.msu.rocks/version"
CLI_URL="https://meridian.msu.rocks/meridian"
AI_DOCS_URL="https://meridian.msu.rocks/ai/reference.md"

# --- State (set during execution) ---
SERVER_IP=""
ANSIBLE_USER="root"
LOCAL_MODE=false
REQUESTED_SERVER=""

# --- Colors & output helpers ---
R='\033[0m' B='\033[1m' D='\033[2m'
G='\033[32m' Y='\033[33m' C='\033[36m' RED='\033[31m'

info()  { printf "  ${C}→${R} %s\n" "$*"; }
ok()    { printf "  ${G}✓${R} %s\n" "$*"; }
warn()  { printf "  ${Y}!${R} %s\n" "$*"; }
fail()  { printf "\n  ${RED}✗ %s${R}\n" "$*" >&2; printf "  ${D}Not connecting? Run: meridian ping | Other issues? Run: meridian diagnostics --ai${R}\n  ${D}Report: https://github.com/uburuntu/meridian/issues${R}\n\n" >&2; exit 1; }
line()  { printf "  ${D}─────────────────────────────────────────${R}\n"; }

# --- AI prompt helpers ---

fetch_ai_docs() {
  local cache="$CACHE_DIR/ai-reference.md"
  local cache_ver="$CACHE_DIR/ai-reference.version"

  if [[ -f "$cache" && -f "$cache_ver" ]] && [[ "$(cat "$cache_ver")" == "$MERIDIAN_VERSION" ]]; then
    cat "$cache"
    return 0
  fi

  local docs
  docs=$(curl -sSf --max-time 10 "$AI_DOCS_URL" </dev/null 2>/dev/null) || {
    # Fallback to cache even if version mismatches
    [[ -f "$cache" ]] && { cat "$cache"; return 0; }
    return 1
  }

  mkdir -p "$CACHE_DIR"
  printf '%s\n' "$docs" > "$cache"
  printf '%s' "$MERIDIAN_VERSION" > "$cache_ver"
  cat "$cache"
}

copy_to_clipboard() {
  local text="$1"
  if command -v pbcopy &>/dev/null; then
    printf '%s' "$text" | pbcopy
    return 0
  elif command -v xclip &>/dev/null; then
    printf '%s' "$text" | xclip -selection clipboard 2>/dev/null
    return 0
  elif command -v xsel &>/dev/null; then
    printf '%s' "$text" | xsel --clipboard 2>/dev/null
    return 0
  fi
  return 1
}

build_ai_prompt() {
  local command_name="$1" output="$2"
  local docs
  docs=$(fetch_ai_docs) || docs="(AI reference docs unavailable. Meridian is a CLI tool that deploys VLESS+Reality proxy servers. See https://github.com/uburuntu/meridian)"

  local size
  local prompt
  prompt="$(cat <<EOF
You are helping troubleshoot a Meridian VPN proxy server deployment.
Meridian is an open-source CLI tool that deploys censorship-resistant VLESS+Reality proxy servers.
The user ran \`meridian $command_name\` and needs help interpreting the results and fixing any issues.

## Meridian Reference Documentation

$docs

## $command_name Output

\`\`\`
$output
\`\`\`

Analyze the output above. Identify any issues and provide specific, actionable steps to fix them.
If you need more information, tell the user what commands to run on their server.
EOF
  )"

  size=$(printf '%s' "$prompt" | wc -c | tr -d ' ')
  local size_kb=$(( size / 1024 ))

  if copy_to_clipboard "$prompt"; then
    printf "\n"
    line
    printf "\n"
    printf "  ${G}${B}Prompt copied to clipboard${R} (%s KB)\n" "$size_kb"
    printf "  Paste into ChatGPT, Claude, or any AI assistant for help.\n\n"
  else
    printf "\n"
    line
    printf "\n"
    printf "  ${B}Copy the prompt below and paste into ChatGPT, Claude, or any AI assistant.${R}\n"
    printf "\n"
    printf "  ━━━ COPY START ━━━\n\n"
    printf '%s\n' "$prompt"
    printf "\n  ━━━ COPY END ━━━\n\n"
  fi
}

prompt() {
  local varname="$1" message="$2" default="${3:-}"
  printf "  ${B}%s${R}" "$message" > /dev/tty
  [[ -n "$default" ]] && printf " ${D}[%s]${R}" "$default" > /dev/tty
  printf ": " > /dev/tty
  local value
  read -r value < /dev/tty || true
  [[ -z "$value" && -n "$default" ]] && value="$default"
  eval "$varname=\$value"
}

confirm() {
  printf "\n  Press ${B}Enter${R} to start, or ${D}Ctrl+C${R} to cancel. " > /dev/tty
  read -r < /dev/tty || true
}

detect_os() {
  if [[ "$OSTYPE" == "darwin"* ]]; then echo "mac"; else echo "linux"; fi
}

OS=$(detect_os)

# =============================================================================
# Server registry — simple line-oriented file: host user name
# =============================================================================

servers_list() {
  [[ -f "$SERVERS_FILE" ]] || return 0
  grep -v '^#' "$SERVERS_FILE" 2>/dev/null | grep -v '^$' || true
}

servers_count() {
  local n
  n=$(servers_list | wc -l)
  echo "${n// /}"
}

servers_find() {
  local query="$1"
  servers_list | awk -v q="$query" '$1 == q || $3 == q {print; exit}'
}

servers_add() {
  local host="$1" user="$2" name="${3:-}"
  mkdir -p "$MERIDIAN_HOME"
  # Remove existing entry for this host
  if [[ -f "$SERVERS_FILE" ]]; then
    grep -v "^${host} " "$SERVERS_FILE" > "$SERVERS_FILE.tmp" 2>/dev/null || true
    mv "$SERVERS_FILE.tmp" "$SERVERS_FILE"
  fi
  echo "$host $user $name" >> "$SERVERS_FILE"
}

servers_remove() {
  local query="$1"
  [[ -f "$SERVERS_FILE" ]] || return 1
  local match
  match=$(servers_find "$query") || return 1
  local host
  host=$(echo "$match" | awk '{print $1}')
  grep -v "^${host} " "$SERVERS_FILE" > "$SERVERS_FILE.tmp" 2>/dev/null || true
  mv "$SERVERS_FILE.tmp" "$SERVERS_FILE"
}

# =============================================================================
# Server resolution
# =============================================================================

resolve_server() {
  # 1. Explicit --server flag
  if [[ -n "$REQUESTED_SERVER" ]]; then
    local match
    match=$(servers_find "$REQUESTED_SERVER") || true
    if [[ -n "$match" ]]; then
      SERVER_IP=$(echo "$match" | awk '{print $1}')
      ANSIBLE_USER=$(echo "$match" | awk '{print $2}')
      return 0
    fi
    if [[ "$REQUESTED_SERVER" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
      SERVER_IP="$REQUESTED_SERVER"
      return 0
    fi
    fail "Server '$REQUESTED_SERVER' not found. Run: meridian server list"
  fi

  # 2. Running on the server itself — /etc/meridian/ exists
  if [[ -f "$SERVER_CREDS_DIR/proxy.yml" ]]; then
    LOCAL_MODE=true
    SERVER_IP=$(grep 'exit_ip:' "$SERVER_CREDS_DIR/proxy.yml" 2>/dev/null | awk '{print $2}' | tr -d '"')
    if [[ -n "$SERVER_IP" ]]; then
      return 0
    fi
  fi

  # 3. Single server auto-select
  local count
  count=$(servers_count)
  if [[ "$count" -eq 1 ]]; then
    local entry
    entry=$(servers_list | head -1)
    SERVER_IP=$(echo "$entry" | awk '{print $1}')
    ANSIBLE_USER=$(echo "$entry" | awk '{print $2}')
    local name
    name=$(echo "$entry" | awk '{print $3}')
    [[ -n "$name" ]] && info "Using server: $name ($SERVER_IP)" || info "Using server: $SERVER_IP"
    return 0
  elif [[ "$count" -gt 1 ]]; then
    printf "\n  Multiple servers. Use ${B}--server NAME${R}:\n\n"
    servers_list | while IFS=' ' read -r h u n; do
      printf "    ${C}%-15s${R}  %s  (%s)\n" "${n:-$h}" "$h" "$u"
    done
    printf "\n"
    fail "Specify a server with --server"
  fi

  # 0 servers
  return 1
}

# Per-server local credentials directory
server_creds() {
  if [[ "$LOCAL_MODE" == true ]]; then
    echo "$SERVER_CREDS_DIR"
  else
    echo "$CREDS_BASE/$SERVER_IP"
  fi
}

# =============================================================================
# Core infrastructure
# =============================================================================

version_parse() {
  # Parse X.Y.Z from version string, sets v_major, v_minor, v_patch
  local ver="$1" prefix="${2:-v}"
  ver="${ver#v}"  # strip leading v
  IFS='.' read -r "${prefix}_major" "${prefix}_minor" "${prefix}_patch" <<< "$ver"
}

do_self_update() {
  # Perform the actual CLI update (shared by auto-patch and manual self-update)
  local target_version="$1"
  local self_path
  self_path=$(command -v meridian 2>/dev/null || echo "$HOME/.local/bin/meridian")
  [[ ! -w "$self_path" ]] && return 1

  local new_cli
  new_cli=$(curl -sSf "$CLI_URL" </dev/null 2>/dev/null) || \
  new_cli=$(curl -sSf "https://raw.githubusercontent.com/uburuntu/meridian/main/meridian" </dev/null 2>/dev/null) || \
    return 1

  [[ "$new_cli" == *"MERIDIAN_VERSION"* ]] || return 1

  printf '%s\n' "$new_cli" > "$self_path"
  chmod +x "$self_path"
  rm -rf "${PLAYBOOKS_DIR:?}"
  mkdir -p "$CACHE_DIR"
  date +%s > "$CACHE_DIR/last_update_check"
  return 0
}

check_for_update() {
  local check_file="$CACHE_DIR/last_update_check"
  mkdir -p "$CACHE_DIR"

  if [[ -f "$check_file" ]]; then
    local last_check
    last_check=$(cat "$check_file" 2>/dev/null || echo "0")
    if [[ "$last_check" =~ ^[0-9]+$ ]]; then
      local now age
      now=$(date +%s)
      age=$(( now - last_check ))
      [[ $age -lt 60 ]] && return 0
    fi
  fi

  local latest
  latest=$(curl -sSf --max-time 3 "$VERSION_URL" </dev/null 2>/dev/null | tr -d '[:space:]') || return 0
  date +%s > "$check_file"

  [[ -z "$latest" || "$latest" == "$MERIDIAN_VERSION" ]] && return 0

  # Parse semver to decide update behavior
  local v_major v_minor v_patch l_major l_minor l_patch
  version_parse "$MERIDIAN_VERSION" "v"
  version_parse "$latest" "l"

  if [[ "$v_major" == "$l_major" && "$v_minor" == "$l_minor" && "$v_patch" != "$l_patch" ]]; then
    # Patch update: auto-update silently
    if do_self_update "$latest"; then
      printf "  ${G}Auto-updated: v${MERIDIAN_VERSION} → v${latest}${R}\n\n"
      MERIDIAN_AUTO_UPDATED=1
    fi
  else
    # Minor or major update: prompt user
    if [[ "$v_major" != "$l_major" ]]; then
      printf "  ${Y}Major update available: v${MERIDIAN_VERSION} → v${latest}${R}\n"
    else
      printf "  ${Y}Update available: v${MERIDIAN_VERSION} → v${latest}${R}\n"
    fi
    printf "  ${D}Run: meridian self-update${R}\n\n"
  fi
}

ensure_deps() {
  local need_qrencode="${1:-true}"

  for p in "$HOME/.local/bin" "$HOME/Library/Python"/*/bin; do
    [[ -d "$p" ]] && [[ ":$PATH:" != *":$p:"* ]] && export PATH="$p:$PATH"
  done

  if ! command -v ansible-playbook &>/dev/null; then
    info "Installing Ansible..."
    install_ansible || fail "Failed to install Ansible. Install manually: pip3 install ansible"
    for p in "$HOME/.local/bin" "$HOME/Library/Python"/*/bin; do
      [[ -d "$p" ]] && [[ ":$PATH:" != *":$p:"* ]] && export PATH="$p:$PATH"
    done
    command -v ansible-playbook &>/dev/null || fail "Ansible installed but not in PATH. Add ~/.local/bin to your PATH."
    ok "Ansible installed"
  fi

  if [[ "$need_qrencode" == "true" ]] && ! command -v qrencode &>/dev/null; then
    info "Installing qrencode..."
    if [[ "$OS" == "mac" ]]; then
      command -v brew &>/dev/null || fail "Homebrew not found. Install from https://brew.sh"
      brew install qrencode || fail "Failed to install qrencode"
    else
      sudo apt-get install -y -qq qrencode >/dev/null 2>&1 || fail "Failed to install qrencode"
    fi
    ok "qrencode installed"
  fi
}

install_ansible() {
  if command -v pipx &>/dev/null; then
    if pipx install ansible --quiet 2>/dev/null; then return 0; fi
  fi
  if command -v pip3 &>/dev/null; then
    if pip3 install --quiet --user ansible 2>/dev/null; then return 0; fi
    if pip3 install --quiet --user --break-system-packages ansible 2>/dev/null; then return 0; fi
  fi
  if [[ "$OS" == "linux" ]]; then
    if sudo apt-get install -y -qq ansible >/dev/null 2>&1; then return 0; fi
  fi
  return 1
}

ensure_playbooks() {
  local version_file="$PLAYBOOKS_DIR/.version"
  mkdir -p "$PLAYBOOKS_DIR"

  if [[ -f "$version_file" && -f "$PLAYBOOKS_DIR/playbook.yml" ]]; then
    local cached_version
    cached_version=$(cat "$version_file" 2>/dev/null)
    [[ "$cached_version" == "$MERIDIAN_VERSION" ]] && return 0
  fi

  info "Downloading playbooks (v${MERIDIAN_VERSION})..."
  local tmp_dir
  tmp_dir=$(mktemp -d)

  local downloaded=false
  if command -v curl &>/dev/null; then
    curl -sSfL "$TARBALL_URL" </dev/null 2>/dev/null | tar xz -C "$tmp_dir" --strip-components=1 && downloaded=true
    [[ "$downloaded" != true ]] && curl -sL "$TARBALL_FALLBACK_URL" </dev/null | tar xz -C "$tmp_dir" --strip-components=1 && downloaded=true
  elif command -v wget &>/dev/null; then
    wget -qO- "$TARBALL_URL" </dev/null 2>/dev/null | tar xz -C "$tmp_dir" --strip-components=1 && downloaded=true
    [[ "$downloaded" != true ]] && wget -qO- "$TARBALL_FALLBACK_URL" </dev/null | tar xz -C "$tmp_dir" --strip-components=1 && downloaded=true
  fi
  if [[ "$downloaded" != true ]]; then
    rm -rf "$tmp_dir"
    fail "Failed to download playbooks. curl or wget required."
  fi

  rm -rf "${PLAYBOOKS_DIR:?}.tmp"
  mv "$tmp_dir" "$PLAYBOOKS_DIR.tmp"
  rm -rf "${PLAYBOOKS_DIR:?}"
  mv "$PLAYBOOKS_DIR.tmp" "$PLAYBOOKS_DIR"
  echo "$MERIDIAN_VERSION" > "$version_file"
  ok "Playbooks ready"

  info "Installing Ansible collections..."
  if ! ansible-galaxy collection install -r "$PLAYBOOKS_DIR/requirements.yml" --quiet 2>/dev/null; then
    ansible-galaxy collection install -r "$PLAYBOOKS_DIR/requirements.yml" || fail "Failed to install Ansible collections"
  fi
  ok "Collections ready"
}

# =============================================================================
# SSH & server helpers
# =============================================================================

detect_local_mode() {
  local local_ip
  local_ip=$(curl -4 -s --max-time 3 https://ifconfig.me </dev/null 2>/dev/null || true)
  [[ "$local_ip" == "$SERVER_IP" ]]
}

check_ssh() {
  if [[ "$LOCAL_MODE" == true ]]; then
    ok "Running on the target server (local mode)"
    return 0
  fi
  info "Checking SSH access to ${ANSIBLE_USER}@${SERVER_IP}..."
  if ssh -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=accept-new "${ANSIBLE_USER}@${SERVER_IP}" true </dev/null 2>/dev/null; then
    ok "SSH connection successful"
  else
    printf "\n"
    fail "Cannot SSH to ${ANSIBLE_USER}@${SERVER_IP}

  Possible fixes:
  1. Copy your SSH key:  ssh-copy-id ${ANSIBLE_USER}@${SERVER_IP}
  2. Test manually:      ssh ${ANSIBLE_USER}@${SERVER_IP}
  3. Different user:     meridian setup IP --user ubuntu"
  fi
}

run_on_server() {
  if [[ "$LOCAL_MODE" == true ]]; then
    bash -c "$1" 2>&1
  else
    ssh -o BatchMode=yes -o ConnectTimeout=5 "${ANSIBLE_USER}@${SERVER_IP}" "$1" </dev/null 2>&1
  fi
}

write_inventory() {
  local inv_file="$PLAYBOOKS_DIR/inventory.yml"
  local become_line=""
  [[ "$ANSIBLE_USER" != "root" ]] && become_line="      ansible_become: true"

  if [[ "$LOCAL_MODE" == true ]]; then
    cat > "$inv_file" <<EOF
all:
  hosts:
    proxy:
      ansible_host: "$SERVER_IP"
      ansible_connection: local
${become_line}
EOF
  else
    cat > "$inv_file" <<EOF
all:
  hosts:
    proxy:
      ansible_host: "$SERVER_IP"
      ansible_user: "$ANSIBLE_USER"
${become_line}
EOF
  fi
}

fetch_credentials_from_server() {
  local creds_dir
  creds_dir=$(server_creds)

  # Already have credentials locally
  [[ -f "$creds_dir/proxy.yml" ]] && return 0

  # In local mode, /etc/meridian/ is the source — nothing to fetch
  [[ "$LOCAL_MODE" == true ]] && return 1

  info "Fetching credentials from server..."
  local remote_cred
  remote_cred=$(ssh -o BatchMode=yes -o ConnectTimeout=3 "${ANSIBLE_USER}@${SERVER_IP}" \
    "cat /etc/meridian/proxy.yml 2>/dev/null" </dev/null 2>/dev/null || true)

  if [[ -n "$remote_cred" && "$remote_cred" == *"panel_configured"* ]]; then
    mkdir -p "$creds_dir" && chmod 700 "$creds_dir"
    printf '%s\n' "$remote_cred" > "$creds_dir/proxy.yml"
    chmod 600 "$creds_dir/proxy.yml"

    # Also fetch clients file
    local remote_clients
    remote_clients=$(ssh -o BatchMode=yes -o ConnectTimeout=3 "${ANSIBLE_USER}@${SERVER_IP}" \
      "cat /etc/meridian/proxy-clients.yml 2>/dev/null" </dev/null 2>/dev/null || true)
    if [[ -n "$remote_clients" ]]; then
      printf '%s\n' "$remote_clients" > "$creds_dir/proxy-clients.yml"
      chmod 600 "$creds_dir/proxy-clients.yml"
    fi

    ok "Fetched credentials from server"
    return 0
  fi

  return 1
}

run_playbook() {
  local playbook="$1"; shift
  local creds_dir
  creds_dir=$(server_creds)
  mkdir -p "$creds_dir"

  cd "$PLAYBOOKS_DIR"
  ansible-playbook -i inventory.yml "$playbook" \
    -e "server_public_ip=$SERVER_IP" \
    -e "credentials_dir=$creds_dir" \
    "$@"
}

install_cli_on_server() {
  if [[ "$LOCAL_MODE" == true ]]; then
    return 0
  fi
  local self_path
  self_path=$(command -v meridian 2>/dev/null || echo "")
  if [[ -n "$self_path" && -f "$self_path" ]]; then
    info "Installing meridian CLI on server..."
    scp -o BatchMode=yes "$self_path" "${ANSIBLE_USER}@${SERVER_IP}:/usr/local/bin/meridian" </dev/null 2>/dev/null && \
      ok "CLI installed on server" || \
      warn "Could not install CLI on server (non-critical)"
  fi
}

# Shared preparation for commands that need server access
prepare_server() {
  local need_qrencode="${1:-true}"
  ensure_deps "$need_qrencode"
  ensure_playbooks

  if [[ "$LOCAL_MODE" != true ]]; then
    if detect_local_mode; then
      LOCAL_MODE=true
    fi
  fi
  check_ssh
  write_inventory
  fetch_credentials_from_server || true
}

# =============================================================================
# Commands
# =============================================================================

cmd_setup() {
  local server_ip="" domain="" email="" sni="" user="root" name="" yes=false xhttp=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain)  domain="$2"; shift 2 ;;
      --email)   email="$2"; shift 2 ;;
      --sni)     sni="$2"; shift 2 ;;
      --user)    user="$2"; shift 2 ;;
      --name)    name="$2"; shift 2 ;;
      --xhttp)   xhttp=true; shift ;;
      --yes|-y)  yes=true; shift ;;
      --help|-h) printf "\n  ${B}meridian setup${R} — Deploy proxy server\n\n"
                 printf "  Usage: meridian setup [IP] [flags]\n\n"
                 printf "  Flags:\n"
                 printf "    --domain DOMAIN   Add CDN fallback via Cloudflare\n"
                 printf "    --sni HOST        Reality camouflage target (default: www.microsoft.com)\n"
                 printf "    --xhttp           Add XHTTP transport (enhanced stealth)\n"
                 printf "    --name NAME       Name the first client (default: 'default')\n"
                 printf "    --user USER       SSH user (default: root)\n"
                 printf "    --yes, -y         Skip confirmation prompts\n\n"
                 exit 0 ;;
      -*)        fail "Unknown flag: $1. Run: meridian setup --help" ;;
      *)         server_ip="$1"; shift ;;
    esac
  done

  ANSIBLE_USER="$user"

  # Interactive wizard if no IP given
  if [[ -z "$server_ip" ]]; then
    printf "  Deploy a VLESS+Reality proxy server.\n"
    printf "  Invisible to DPI, active probing, and TLS fingerprinting.\n"
    printf "  Your server will impersonate ${D}${sni:-www.microsoft.com}${R} — probes\n"
    printf "  get a real TLS certificate back. Takes ~2 minutes. Safe to re-run.\n"
    printf "\n"
    line
    printf "\n"
    printf "  ${B}Where is the server?${R}\n\n"

    local detected_ip
    detected_ip=$(curl -4 -s --max-time 3 https://ifconfig.me </dev/null 2>/dev/null || \
                  curl -4 -s --max-time 3 https://api.ipify.org </dev/null 2>/dev/null || true)
    if ! [[ "$detected_ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
      detected_ip=""
    fi

    while true; do
      prompt server_ip "IP address" "$detected_ip"
      [[ "$server_ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]] && break
      printf "  ${RED}Enter a valid IPv4 address (e.g. 123.45.67.89)${R}\n" > /dev/tty
    done

    prompt ANSIBLE_USER "SSH user" "root"
    [[ "$ANSIBLE_USER" != "root" ]] && printf "  ${D}(sudo will be used for privileged operations)${R}\n" > /dev/tty

    printf "\n"
    printf "  ${B}Optional — CDN fallback:${R}\n\n"

    # Suggest domain from saved credentials
    local suggested_domain=""
    local creds_dir="$CREDS_BASE/$server_ip"
    if [[ -f "$creds_dir/proxy.yml" ]]; then
      suggested_domain=$(grep '^domain:' "$creds_dir/proxy.yml" 2>/dev/null | awk '{print $2}' | tr -d '"' || true)
    fi
    [[ -n "$suggested_domain" ]] && printf "  ${D}Detected: ${suggested_domain}${R}\n" > /dev/tty
    prompt domain "Domain" "${suggested_domain:-skip}"
    [[ "$domain" == "skip" || "$domain" == "" ]] && domain=""

    printf "\n"
    line
    printf "\n"
    printf "  ${B}Summary${R}\n\n"
    printf "  Target:  ${G}${ANSIBLE_USER}@${server_ip}${R}\n"
    if [[ -n "$domain" ]]; then
      printf "  Domain:  ${G}${domain}${R}\n"
      printf "  Mode:    Reality + CDN fallback\n"
    else
      printf "  Domain:  ${D}(none)${R}\n"
      printf "  Mode:    Standalone (Reality only)\n"
    fi
    printf "\n"
    line

    [[ "$yes" != true ]] && confirm
    printf "\n"
  fi

  [[ "$server_ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]] || fail "Invalid IP address: $server_ip"

  SERVER_IP="$server_ip"
  prepare_server true

  # Suggest scanned SNI if available and no --sni was given
  if [[ -z "$sni" ]]; then
    local scanned_sni=""
    local creds_check="$CREDS_BASE/$SERVER_IP"
    if [[ -f "$creds_check/proxy.yml" ]]; then
      scanned_sni=$(grep '^scanned_sni:' "$creds_check/proxy.yml" 2>/dev/null | awk '{print $2}' | tr -d '"' || true)
    fi
    if [[ -n "$scanned_sni" ]]; then
      info "Detected optimal SNI from scan: $scanned_sni"
      if [[ "$yes" == true ]]; then
        sni="$scanned_sni"
      else
        local use_scanned=""
        prompt use_scanned "Use $scanned_sni as SNI target? (Y/n)"
        if [[ "$use_scanned" != "n" && "$use_scanned" != "N" ]]; then
          sni="$scanned_sni"
        fi
      fi
    fi
  fi

  local play_args=()
  [[ -n "$domain" ]] && play_args+=(-e "domain=$domain")
  [[ -n "$email" ]]  && play_args+=(-e "email=$email")
  [[ -n "$sni" ]]    && play_args+=(-e "reality_sni=$sni")
  [[ -n "$name" ]]   && play_args+=(-e "first_client_name=$name")
  [[ "$xhttp" == true ]] && play_args+=(-e "xhttp_enabled=true")

  printf "\n"
  info "Configuring server at $SERVER_IP..."
  [[ -n "$domain" ]] && info "Domain: $domain"
  [[ "$xhttp" == true ]] && info "XHTTP: enabled (enhanced stealth)"
  printf "\n"

  run_playbook playbook.yml ${play_args[@]+"${play_args[@]}"}

  # Register server
  servers_add "$SERVER_IP" "$ANSIBLE_USER" ""

  # Install CLI on server
  install_cli_on_server

  # Done
  local creds_dir
  creds_dir=$(server_creds)
  local client_label="${name:-default}"
  local html_file
  html_file=$(ls "$creds_dir"/*-"${client_label}"-connection-info.html 2>/dev/null | head -1)
  local txt_file
  txt_file=$(ls "$creds_dir"/*-connection-info.txt 2>/dev/null | head -1)

  printf "\n  ${G}${B}Done!${R}\n\n"
  printf "  ${B}Next steps:${R}\n\n"
  if [[ -n "${html_file:-}" ]]; then
    printf "  ${G}1.${R} Send this file to whoever needs access:\n"
    printf "     ${B}${html_file}${R}\n"
    printf "     ${D}(They open it, scan the QR code, and connect)${R}\n\n"
  fi
  if [[ -n "${txt_file:-}" ]]; then
    printf "  ${G}2.${R} View connection details:\n"
    printf "     ${C}cat ${txt_file}${R}\n\n"
  fi
  printf "  ${G}3.${R} Share access with friends:\n"
  printf "     ${C}meridian client add alice${R}\n"
  printf "     ${C}meridian client list${R}\n\n"
  printf "  ${G}4.${R} View full credentials:\n"
  printf "     ${C}cat ${creds_dir}/proxy.yml${R}\n"
  printf "\n"
  line
  printf "\n  ${D}Feedback & issues: https://github.com/uburuntu/meridian/issues${R}\n\n"
}

# Display client list from panel API JSON response.
# Uses python3 for JSON parsing (available on all supported systems).
client_list_display() {
  local json="$1" domain="${2:-}"
  local success
  success=$(printf '%s' "$json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('success',''))" 2>/dev/null)
  [[ "$success" == "True" ]] || fail "Panel API error"

  python3 -c "
import sys, json

data = json.loads(sys.argv[1])
inbounds = data.get('obj', [])

# Build lookup: inbound remark -> set of client emails
clients_by_inbound = {}
for ib in inbounds:
    remark = ib.get('remark', '')
    settings = json.loads(ib.get('settings', '{}'))
    emails = {c.get('email', '') for c in settings.get('clients', [])}
    clients_by_inbound[remark] = emails

# Reality clients are the canonical list
reality_clients = []
for ib in inbounds:
    if ib.get('remark') == 'VLESS-Reality':
        settings = json.loads(ib.get('settings', '{}'))
        reality_clients = settings.get('clients', [])
        break

wss_emails = clients_by_inbound.get('VLESS-WSS', set())
xhttp_emails = clients_by_inbound.get('VLESS-Reality-XHTTP', set())

print()
print('  ======================================================================')
print('                        PROXY CLIENTS')
print('  ======================================================================')
print()
print('    Name              Status     Protocols')
print('    ' + '─' * 49)

for c in reality_clients:
    email = c.get('email', '')
    name = email.replace('reality-', '', 1) if email.startswith('reality-') else email
    status = 'active' if c.get('enable', True) else 'disabled'
    protos = ['Reality']
    if f'xhttp-{name}' in xhttp_emails:
        protos.append('XHTTP')
    if f'wss-{name}' in wss_emails:
        protos.append('WSS')
    print(f'    {name:<17s} {status:<10s} {\" + \".join(protos)}')

print()
print('    ' + '─' * 49)
print(f'    Total: {len(reality_clients)} client{\"s\" if len(reality_clients) != 1 else \"\"}')
print()
print('  ======================================================================')
print()
" "$json"
}

cmd_client() {
  local action="${1:-}"
  shift || true

  case "$action" in
    add)
      local client_name=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --user) ANSIBLE_USER="$2"; shift 2 ;;
          -*) fail "Unknown flag: $1" ;;
          *)  client_name="$1"; shift ;;
        esac
      done
      [[ -z "$client_name" ]] && fail "Usage: meridian client add NAME"
      resolve_server || fail "No servers configured. Run: meridian setup"
      prepare_server true

      info "Adding client '$client_name'..."
      printf "\n"
      run_playbook playbook-client.yml -e "client_action=add" -e "client_name=$client_name"

      local creds_dir
      creds_dir=$(server_creds)
      local html_file
      html_file=$(ls "$creds_dir"/*-"${client_name}"-connection-info.html 2>/dev/null | head -1)
      if [[ -n "${html_file:-}" ]]; then
        printf "\n  ${G}${B}Done!${R}\n\n"
        printf "  Send this file to %s:\n" "$client_name"
        printf "     ${B}${html_file}${R}\n\n"
      fi
      ;;

    list)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --user) ANSIBLE_USER="$2"; shift 2 ;;
          -*) fail "Unknown flag: $1" ;;
          *)  shift ;;
        esac
      done
      resolve_server || fail "No servers configured. Run: meridian setup"

      local creds_dir
      creds_dir=$(server_creds)
      [[ -f "$creds_dir/proxy.yml" ]] || fail "No credentials found. Run: meridian setup"

      # Read credentials from proxy.yml
      local panel_user panel_pass panel_path panel_port
      panel_user=$(grep '^panel_username:' "$creds_dir/proxy.yml" | awk '{print $2}' | tr -d '"')
      panel_pass=$(grep '^panel_password:' "$creds_dir/proxy.yml" | awk '{print $2}' | tr -d '"')
      panel_path=$(grep '^panel_web_base_path:' "$creds_dir/proxy.yml" | awk '{print $2}' | tr -d '"')
      panel_port=2053
      local domain
      domain=$(grep '^domain:' "$creds_dir/proxy.yml" | awk '{print $2}' | tr -d '"')

      # Query panel API — write a script to the server to avoid credential
      # quoting issues in SSH command interpolation
      local json
      if [[ "$LOCAL_MODE" == true ]]; then
        json=$(curl -s -c /tmp/.mc -d "username=${panel_user}&password=${panel_pass}" \
          "http://127.0.0.1:${panel_port}/${panel_path}/login" > /dev/null && \
          curl -s -b /tmp/.mc "http://127.0.0.1:${panel_port}/${panel_path}/panel/api/inbounds/list" ; \
          rm -f /tmp/.mc) || fail "Failed to connect to panel API"
      else
        json=$(ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10 \
          "${ANSIBLE_USER:-root}@${SERVER_IP}" \
          "bash -s" </dev/null 2>/dev/null <<REMOTESCRIPT
curl -s -c /tmp/.mc -d "username=${panel_user}&password=${panel_pass}" \
  "http://127.0.0.1:${panel_port}/${panel_path}/login" > /dev/null && \
curl -s -b /tmp/.mc "http://127.0.0.1:${panel_port}/${panel_path}/panel/api/inbounds/list"
rm -f /tmp/.mc
REMOTESCRIPT
        ) || fail "Failed to connect to panel API"
      fi

      client_list_display "$json" "$domain"
      ;;

    remove)
      local client_name=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --user) ANSIBLE_USER="$2"; shift 2 ;;
          -*) fail "Unknown flag: $1" ;;
          *)  client_name="$1"; shift ;;
        esac
      done
      [[ -z "$client_name" ]] && fail "Usage: meridian client remove NAME"
      resolve_server || fail "No servers configured. Run: meridian setup"
      prepare_server false

      info "Removing client '$client_name'..."
      printf "\n"
      run_playbook playbook-client.yml -e "client_action=remove" -e "client_name=$client_name"
      ;;

    ""|--help|-h)
      printf "\n  ${B}meridian client${R} — Manage proxy clients\n\n"
      printf "  Commands:\n"
      printf "    add NAME      Add a new client key\n"
      printf "    list          List all clients\n"
      printf "    remove NAME   Remove a client key\n\n"
      printf "  Flags:\n"
      printf "    --server NAME   Target a specific server\n"
      printf "    --user USER     SSH user (default: root)\n\n"
      ;;

    *)
      fail "Unknown client command: $action. Run: meridian client --help"
      ;;
  esac
}

cmd_server() {
  local action="${1:-}"
  shift || true

  case "$action" in
    add)
      local host="" user="root" name=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --user) user="$2"; shift 2 ;;
          --name) name="$2"; shift 2 ;;
          -*) fail "Unknown flag: $1" ;;
          *)  host="$1"; shift ;;
        esac
      done
      [[ -z "$host" ]] && fail "Usage: meridian server add IP [--name NAME] [--user USER]"
      if [[ -n "$name" ]] && ! [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]*$ ]]; then
        fail "Server name must be alphanumeric (hyphens and underscores allowed)"
      fi

      SERVER_IP="$host"
      ANSIBLE_USER="$user"
      LOCAL_MODE=false

      info "Connecting to $host..."
      check_ssh
      fetch_credentials_from_server || warn "No credentials found on server (run meridian setup first)"

      servers_add "$host" "$user" "$name"
      ok "Server added: ${name:-$host}"
      ;;

    list)
      local count
      count=$(servers_count)
      if [[ "$count" -eq 0 ]]; then
        info "No servers configured. Run: meridian setup IP"
        return
      fi
      printf "\n"
      printf "  ${B}%-15s  %-15s  %-8s${R}\n" "NAME" "IP" "USER"
      line
      servers_list | while IFS=' ' read -r h u n; do
        printf "  %-15s  %-15s  %-8s\n" "${n:---}" "$h" "$u"
      done
      printf "\n"
      ;;

    remove)
      local query="${1:-}"
      [[ -z "$query" ]] && fail "Usage: meridian server remove NAME|IP"

      local match
      match=$(servers_find "$query") || fail "Server '$query' not found"
      local host
      host=$(echo "$match" | awk '{print $1}')

      servers_remove "$query"
      rm -rf "${CREDS_BASE:?}/$host"
      ok "Server removed: $query"
      ;;

    ""|--help|-h)
      printf "\n  ${B}meridian server${R} — Manage known servers\n\n"
      printf "  Commands:\n"
      printf "    add IP [--name NAME] [--user USER]   Register a server\n"
      printf "    list                                  List known servers\n"
      printf "    remove NAME|IP                        Forget a server\n\n"
      ;;

    *)
      fail "Unknown server command: $action. Run: meridian server --help"
      ;;
  esac
}

cmd_check() {
  local server_ip="" domain="" sni="" ai_mode=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain)  domain="$2"; shift 2 ;;
      --sni)     sni="$2"; shift 2 ;;
      --user)    ANSIBLE_USER="$2"; shift 2 ;;
      --ai)      ai_mode=true; shift ;;
      -*)        fail "Unknown flag: $1" ;;
      *)         server_ip="$1"; shift ;;
    esac
  done

  if [[ -n "$server_ip" ]]; then
    SERVER_IP="$server_ip"
  else
    resolve_server || fail "Server IP required. Usage: meridian check IP"
  fi

  if [[ "$LOCAL_MODE" != true ]]; then
    detect_local_mode && LOCAL_MODE=true
  fi
  check_ssh

  printf "\n"
  printf "  ${B}Pre-flight Check${R}\n"
  printf "  ${D}Testing if this server can run a Reality proxy${R}\n"
  printf "\n"

  local issues=0
  local sni_host="${sni:-www.microsoft.com}"

  info "Checking SNI target ($sni_host) reachability from server..."
  local sni_check
  sni_check=$(run_on_server "timeout 5 bash -c 'echo | openssl s_client -connect $sni_host:443 -servername $sni_host 2>/dev/null | head -1'" || true)
  [[ -z "$sni_check" ]] && sni_check=$(run_on_server "timeout 3 bash -c 'echo >/dev/tcp/$sni_host/443' 2>&1 && echo OK" || true)
  if [[ "$sni_check" == *"CONNECTED"* || "$sni_check" == *"OK"* || "$sni_check" == *"Certificate"* ]]; then
    ok "$sni_host is reachable from server"
  else
    warn "$sni_host is NOT reachable from server"
    issues=$((issues + 1))
  fi

  # ASN mismatch check (best-effort, non-blocking)
  info "Checking SNI target ASN match..."
  local server_org sni_ip sni_org
  server_org=$(run_on_server "curl -s --max-time 5 https://ipinfo.io/org 2>/dev/null" || true)
  sni_ip=$(run_on_server "dig +short $sni_host @8.8.8.8 2>/dev/null | grep -E '^[0-9]+\.' | head -1" || true)
  if [[ -n "$server_org" && -n "$sni_ip" && "$sni_ip" =~ ^[0-9]+\. ]]; then
    sni_org=$(run_on_server "curl -s --max-time 5 https://ipinfo.io/$sni_ip/org 2>/dev/null" || true)
    if [[ -n "$sni_org" ]]; then
      # Extract AS number for comparison
      local server_asn sni_asn
      server_asn=$(echo "$server_org" | awk '{print $1}')
      sni_asn=$(echo "$sni_org" | awk '{print $1}')
      if [[ "$server_asn" == "$sni_asn" ]]; then
        ok "SNI target is on the same ASN ($server_asn)"
      else
        # Check for known-bad SNI targets (proprietary ASNs or domains)
        if [[ "$sni_org" == *"Apple"* || "$sni_host" == *"icloud.com"* || "$sni_host" == *"apple.com"* ]]; then
          warn "SNI target ($sni_host) is risky — Apple infrastructure, detectable ASN mismatch"
          printf "       %s\n" "Use a global CDN domain: www.microsoft.com, www.twitch.tv, github.com"
          issues=$((issues + 1))
        else
          info "SNI on different ASN (server: $server_org, SNI: $sni_org)"
          printf "       %s\n" "Fine for global CDN domains. For best stealth, run: meridian scan"
        fi
      fi
    else
      ok "ASN check skipped (could not resolve SNI org)"
    fi
  else
    ok "ASN check skipped (ipinfo.io unavailable)"
  fi

  info "Checking port 443 availability..."
  local port_check
  port_check=$(run_on_server "ss -tlnp sport = :443 2>/dev/null | grep LISTEN" || true)
  if [[ -z "$port_check" ]]; then
    ok "Port 443 is available"
  else
    local port_user
    port_user=$(echo "$port_check" | sed -n 's/.*users:(("\([^"]*\)".*/\1/p' | head -1)
    [[ -z "$port_user" ]] && port_user="unknown"
    if [[ "$port_user" == "haproxy" || "$port_user" == "3x-ui" || "$port_user" == "xray" || "$port_user" == "caddy" ]]; then
      ok "Port 443 is in use by $port_user (Meridian — OK)"
    else
      warn "Port 443 is in use by: $port_user"
      issues=$((issues + 1))
    fi
  fi

  info "Checking port 443 external reachability..."
  if timeout 5 bash -c "echo >/dev/tcp/$SERVER_IP/443" 2>/dev/null; then
    ok "Port 443 is reachable from outside"
  else
    local port_listen
    port_listen=$(run_on_server "ss -tlnp sport = :443 2>/dev/null | grep -c LISTEN" || echo "0")
    if [[ "$port_listen" == "0" ]]; then
      ok "Port 443 not yet listening (expected before install)"
    else
      warn "Port 443 is listening on server but not reachable from outside"
      printf "       %s\n" "Check your cloud provider's firewall / security group settings."
      printf "       %s\n" "Port 443 (TCP) must be allowed for inbound traffic."
      issues=$((issues + 1))
    fi
  fi

  if [[ -n "$domain" ]]; then
    info "Checking domain DNS ($domain)..."
    local dns_result
    dns_result=$(run_on_server "dig +short $domain @8.8.8.8 2>/dev/null" || true)
    if [[ "$dns_result" == *"$SERVER_IP"* ]]; then
      ok "$domain resolves to $SERVER_IP"
    elif [[ -n "$dns_result" ]]; then
      warn "$domain resolves to $dns_result (expected $SERVER_IP)"
      issues=$((issues + 1))
    else
      warn "$domain does not resolve"
      issues=$((issues + 1))
    fi
  fi

  info "Checking server OS..."
  local os_info
  os_info=$(run_on_server "cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d= -f2 | tr -d '\"'" || true)
  if [[ "$os_info" == *"Ubuntu"* || "$os_info" == *"Debian"* ]]; then
    ok "Server OS: $os_info"
  elif [[ -n "$os_info" ]]; then
    warn "Server OS: $os_info (tested on Ubuntu/Debian only)"
    issues=$((issues + 1))
  fi

  info "Checking disk space..."
  local disk_avail
  disk_avail=$(run_on_server "df -BG / 2>/dev/null | tail -1 | awk '{print \$4}' | tr -d 'G'" || true)
  if [[ -n "$disk_avail" ]] && [[ "$disk_avail" -ge 2 ]]; then
    ok "Disk space: ${disk_avail}G available"
  elif [[ -n "$disk_avail" ]]; then
    warn "Only ${disk_avail}G disk space available (need at least 2G)"
    issues=$((issues + 1))
  fi

  # Clock drift check (Reality requires <30s between client and server)
  info "Checking clock sync..."
  local server_epoch client_epoch drift
  server_epoch=$(run_on_server "date +%s" || true)
  client_epoch=$(date +%s)
  if [[ -n "$server_epoch" && "$server_epoch" =~ ^[0-9]+$ ]]; then
    drift=$(( server_epoch - client_epoch ))
    [[ $drift -lt 0 ]] && drift=$(( -drift ))
    if [[ $drift -gt 30 ]]; then
      warn "Clock drift: ${drift}s between client and server (Reality needs <30s)"
      printf "       %s\n" "Fix: ssh root@$SERVER_IP 'timedatectl set-ntp true'"
      printf "       %s\n" "Also check your device's date/time — enable automatic time."
      issues=$((issues + 1))
    else
      ok "Clock sync OK (${drift}s drift)"
    fi
  fi

  printf "\n"
  line
  printf "\n"
  if [[ "$issues" -eq 0 ]]; then
    printf "  ${G}${B}All checks passed.${R} Ready to install.\n\n"
    printf "  ${D}After setup, test from your phone/laptop: meridian ping${R}\n"
    local ping_url="https://meridian.msu.rocks/ping?ip=${SERVER_IP}"
    [[ -n "${domain:-}" ]] && ping_url="${ping_url}&domain=${domain}"
    printf "  ${D}Or use: %s${R}\n\n" "$ping_url"
  else
    printf "  ${Y}${B}$issues issue(s) found.${R} Review the warnings above.\n\n"
    if [[ "$ai_mode" != true ]]; then
      printf "  ${D}Get AI help: meridian check $SERVER_IP --ai${R}\n\n"
    fi
  fi

  if [[ "$ai_mode" == true ]]; then
    local check_output="Pre-flight Check for $SERVER_IP"
    check_output="$check_output\nSNI target ($sni_host): $(if [[ "$sni_check" == *"CONNECTED"* || "$sni_check" == *"OK"* || "$sni_check" == *"Certificate"* ]]; then echo "reachable"; else echo "NOT reachable"; fi)"
    check_output="$check_output\nPort 443: $(if [[ -z "$port_check" ]]; then echo "available"; else echo "in use by ${port_user:-unknown}"; fi)"
    check_output="$check_output\nPort 443 external: $(if timeout 3 bash -c "echo >/dev/tcp/$SERVER_IP/443" 2>/dev/null; then echo "reachable"; else echo "not reachable"; fi)"
    [[ -n "$domain" ]] && check_output="$check_output\nDomain DNS ($domain): ${dns_result:-no result}"
    [[ -n "$os_info" ]] && check_output="$check_output\nServer OS: $os_info"
    [[ -n "$disk_avail" ]] && check_output="$check_output\nDisk space: ${disk_avail}G available"
    check_output="$check_output\nIssues found: $issues"
    build_ai_prompt "check" "$(printf '%b' "$check_output")"
  fi
}

cmd_scan() {
  local server_ip=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user)  ANSIBLE_USER="$2"; shift 2 ;;
      -*)      fail "Unknown flag: $1" ;;
      *)       server_ip="$1"; shift ;;
    esac
  done

  if [[ -n "$server_ip" ]]; then
    SERVER_IP="$server_ip"
  else
    resolve_server || fail "Server IP required. Usage: meridian scan IP"
  fi

  if [[ "$LOCAL_MODE" != true ]]; then
    detect_local_mode && LOCAL_MODE=true
  fi
  check_ssh

  printf "\n"
  printf "  ${B}SNI Scanner${R}\n"
  printf "  ${D}Finding optimal Reality SNI targets near your server...${R}\n"
  printf "\n"

  # Detect server architecture
  local arch
  arch=$(run_on_server "uname -m" || true)
  case "$arch" in
    x86_64)  arch="64" ;;
    aarch64) warn "RealiTLScanner has no arm64 build. You can set SNI manually with --sni."; return 0 ;;
    *)       fail "Unsupported architecture: $arch" ;;
  esac

  # Download RealiTLScanner to server
  local scanner_url="https://github.com/XTLS/RealiTLScanner/releases/latest/download/RealiTLScanner-linux-${arch}"
  info "Downloading RealiTLScanner..."
  run_on_server "curl -sSfL --max-time 30 -o /tmp/realitlscanner '$scanner_url' </dev/null && chmod +x /tmp/realitlscanner" || \
    fail "Failed to download RealiTLScanner. Check network connectivity."

  # Get server's subnet CIDR for scanning
  local server_cidr
  server_cidr=$(run_on_server "ip addr show | grep 'inet ' | grep -v '127.0.0\|172.17\|10.0\|192.168' | head -1 | awk '{print \$2}'" || true)
  [[ -z "$server_cidr" ]] && server_cidr="${SERVER_IP}/24"

  # Run scan on the server's subnet
  info "Scanning $server_cidr for TLS targets (this takes 30-60 seconds)..."
  run_on_server "cd /tmp && timeout 90 ./realitlscanner -addr '$server_cidr' -out /tmp/meridian-scan.csv -thread 4 -timeout 5 >/dev/null 2>&1" || true

  # Clean up binary, read CSV, then clean CSV
  run_on_server "rm -f /tmp/realitlscanner" 2>/dev/null || true
  local csv_output
  csv_output=$(run_on_server "cat /tmp/meridian-scan.csv 2>/dev/null" || true)
  run_on_server "rm -f /tmp/meridian-scan.csv" 2>/dev/null || true

  if [[ -z "$csv_output" || "$csv_output" == "IP,ORIGIN,CERT_DOMAIN,CERT_ISSUER,GEO_CODE" ]]; then
    warn "Scan produced no results. The server may have limited network visibility."
    printf "\n  ${D}You can manually set SNI with: meridian setup $SERVER_IP --sni DOMAIN${R}\n\n"
    return 0
  fi

  # Parse CSV: extract cert_domain (column 3), skip header, deduplicate, filter bad targets
  local domains=()
  while IFS=',' read -r ip origin cert_domain cert_issuer geo; do
    [[ "$ip" == "IP" ]] && continue  # skip header
    [[ -z "$cert_domain" ]] && continue
    # Skip wildcard certs (less useful as SNI targets)
    [[ "$cert_domain" == \** ]] && continue
    # Filter out known-bad targets
    case "$cert_domain" in
      *apple.com|*icloud.com) continue ;;
    esac
    # Skip the server's own domain
    [[ "$cert_domain" == *"$SERVER_IP"* ]] && continue
    # Deduplicate
    local dup=false
    for d in "${domains[@]:-}"; do
      [[ "$d" == "$cert_domain" ]] && { dup=true; break; }
    done
    [[ "$dup" == true ]] && continue
    domains+=("$cert_domain")
  done <<< "$csv_output"

  if [[ ${#domains[@]} -eq 0 ]]; then
    warn "No suitable SNI targets found."
    printf "\n  ${D}You can manually set SNI with: meridian setup $SERVER_IP --sni DOMAIN${R}\n\n"
    return 0
  fi

  printf "\n"
  line
  printf "\n"
  printf "  ${B}Found %d SNI targets:${R}\n\n" "${#domains[@]}"

  local i=1
  for domain in "${domains[@]}"; do
    printf "    ${C}%d${R}) %s\n" "$i" "$domain"
    i=$((i + 1))
  done

  printf "\n"
  local choice
  prompt choice "Select a target (1-${#domains[@]}) or press Enter to skip"

  if [[ -n "$choice" && "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 && "$choice" -le ${#domains[@]} ]]; then
    local selected="${domains[$((choice - 1))]}"

    # Save to credentials
    local creds_dir
    creds_dir=$(server_creds)
    mkdir -p "$creds_dir"

    if [[ -f "$creds_dir/proxy.yml" ]]; then
      # Update existing credentials
      if grep -q '^scanned_sni:' "$creds_dir/proxy.yml" 2>/dev/null; then
        sed -i.bak "s/^scanned_sni:.*/scanned_sni: \"$selected\"/" "$creds_dir/proxy.yml"
        rm -f "$creds_dir/proxy.yml.bak"
      else
        printf 'scanned_sni: "%s"\n' "$selected" >> "$creds_dir/proxy.yml"
      fi
    else
      printf 'scanned_sni: "%s"\n' "$selected" > "$creds_dir/proxy.yml"
    fi

    printf "\n"
    ok "Saved: $selected"
    printf "  ${D}Use it: meridian setup $SERVER_IP --sni $selected${R}\n"
    printf "  ${D}Or it will be suggested automatically during setup.${R}\n"
    printf "  ${D}Tip: with --domain, your own domain works as SNI too (self-steal).${R}\n\n"
  else
    info "Skipped. You can set SNI manually with --sni flag."
    printf "\n"
  fi
}

cmd_diagnostics() {
  local server_ip="" sni="" ai_mode=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --sni)   sni="$2"; shift 2 ;;
      --user)  ANSIBLE_USER="$2"; shift 2 ;;
      --ai)    ai_mode=true; shift ;;
      -*)      fail "Unknown flag: $1" ;;
      *)       server_ip="$1"; shift ;;
    esac
  done

  if [[ -n "$server_ip" ]]; then
    SERVER_IP="$server_ip"
  else
    resolve_server || fail "Server IP required. Usage: meridian diagnostics IP"
  fi

  if [[ "$LOCAL_MODE" != true ]]; then
    detect_local_mode && LOCAL_MODE=true
  fi
  check_ssh

  printf "\n"
  printf "  ${B}Meridian Diagnostics${R}\n"
  printf "  ${D}Collecting system info for bug reports...${R}\n"
  printf "  ${Y}Note: secrets (passwords, UUIDs, keys) are redacted.${R}\n"
  printf "\n"

  local diag=""
  add_section() { diag="${diag}\n### $1\n\`\`\`\n$2\n\`\`\`\n"; }

  add_section "Local Machine" "OS: $(uname -a 2>&1)\nAnsible: $(command -v ansible &>/dev/null && ansible --version 2>&1 | head -1 || echo 'not installed')\nMeridian: $MERIDIAN_VERSION"
  add_section "Server" "$(run_on_server 'cat /etc/os-release 2>/dev/null | grep PRETTY_NAME' || echo unknown)\nKernel: $(run_on_server 'uname -r' || echo unknown)\n$(run_on_server uptime || echo unknown)\nDisk: $(run_on_server 'df -h / 2>/dev/null | tail -1' || echo unknown)\nMemory: $(run_on_server 'free -h 2>/dev/null | grep Mem' || echo unknown)"

  local docker_ver docker_ps
  docker_ver=$(run_on_server "docker --version 2>&1" || echo "not installed")
  docker_ps=$(run_on_server "docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' 2>&1" || echo "no containers")
  add_section "Docker" "$docker_ver\n$docker_ps"

  local xray_logs
  xray_logs=$(run_on_server "docker logs 3x-ui --tail 50 2>&1 | grep -v '^\s*$' | sort -u | tail -20" || echo "container not running")
  xray_logs=$(printf '%s' "$xray_logs" | sed -E 's/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/[UUID-REDACTED]/g; s/([Pp]assword|[Kk]ey|[Ss]ecret)[=: ]*[^ ]*/\1=[REDACTED]/g')
  add_section "3x-ui Logs" "$xray_logs"
  add_section "Listening Ports" "$(run_on_server 'ss -tlnp sport = :443 or sport = :80 or sport = :8443 or sport = :8444 2>&1' || echo unknown)"
  add_section "Firewall (UFW)" "$(run_on_server 'ufw status verbose 2>&1' || echo 'ufw not available')"

  local sni_host="${sni:-www.microsoft.com}"
  add_section "SNI Target ($sni_host)" "$(run_on_server "echo | openssl s_client -connect $sni_host:443 -servername $sni_host 2>/dev/null | grep -E 'subject=|issuer=|CONNECTED'" || echo unreachable)"

  local creds_dir
  creds_dir=$(server_creds)
  if [[ -f "$creds_dir/proxy.yml" ]]; then
    local saved_domain
    saved_domain=$(grep '^domain:' "$creds_dir/proxy.yml" 2>/dev/null | awk '{print $2}' | tr -d '"' || true)
    if [[ -n "$saved_domain" ]]; then
      add_section "Domain DNS ($saved_domain)" "$(run_on_server "dig +short $saved_domain @8.8.8.8 2>/dev/null" || echo 'dig not available')"
    fi
  fi

  printf "\n"
  line
  printf "\n"
  printf "  ${B}Diagnostics collected.${R}\n\n"

  if [[ "$ai_mode" == true ]]; then
    local diag_plain
    diag_plain=$(printf '%b' "$diag")
    build_ai_prompt "diagnostics" "$diag_plain"
  else
    printf "  1. Review the output below for any private info you want to remove\n"
    printf "  2. Copy the markdown block into a new issue:\n"
    printf "     ${C}https://github.com/uburuntu/meridian/issues/new${R}\n"
    printf "\n"
    line
    printf "\n"
    printf '%b' "$diag"
    printf "\n"
    line
    printf "\n"
    printf "  ${D}Secrets (UUIDs, passwords, keys) are auto-redacted.${R}\n\n"
    printf "  ${D}Or get AI help: meridian diagnostics --ai${R}\n\n"
  fi
}

cmd_uninstall() {
  local server_ip="" yes=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user)   ANSIBLE_USER="$2"; shift 2 ;;
      --yes|-y) yes=true; shift ;;
      -*)       fail "Unknown flag: $1" ;;
      *)        server_ip="$1"; shift ;;
    esac
  done

  if [[ -n "$server_ip" ]]; then
    SERVER_IP="$server_ip"
  else
    resolve_server || {
      prompt server_ip "Server IP to uninstall from"
      [[ -z "$server_ip" ]] && fail "Server IP is required for uninstall"
      SERVER_IP="$server_ip"
    }
  fi

  printf "\n"
  warn "This will remove Meridian from $SERVER_IP."
  warn "Docker and system packages will NOT be touched."
  printf "\n"
  if [[ "$yes" != true ]]; then
    prompt CONFIRM "Continue? (y/N)"
    [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]] && { info "Cancelled."; exit 0; }
  fi
  printf "\n"

  prepare_server false

  info "Removing Meridian from $SERVER_IP..."
  printf "\n"
  run_playbook playbook-uninstall.yml

  # Remove from server registry
  servers_remove "$SERVER_IP" 2>/dev/null || true
  rm -rf "${CREDS_BASE:?}/$SERVER_IP"

  printf "\n  ${G}${B}Uninstall complete.${R}\n\n"
}

cmd_self_update() {
  info "Checking for updates..."

  local latest
  latest=$(curl -sSf --max-time 10 "$VERSION_URL" </dev/null 2>/dev/null | tr -d '[:space:]') || \
    fail "Cannot reach update server"

  if [[ "$latest" == "$MERIDIAN_VERSION" ]]; then
    ok "Already up to date (v${MERIDIAN_VERSION})"
    return 0
  fi

  info "Updating from v${MERIDIAN_VERSION} to v${latest}..."

  local self_path
  self_path=$(command -v meridian 2>/dev/null || echo "$HOME/.local/bin/meridian")
  [[ ! -w "$self_path" ]] && fail "Cannot update $self_path — permission denied. Try: sudo meridian self-update"

  do_self_update "$latest" || fail "Failed to download update"

  ok "Updated to v${latest}"
  printf "  ${D}Playbooks will be re-downloaded on next command.${R}\n\n"
}

cmd_version() {
  printf "meridian %s\n" "$MERIDIAN_VERSION"
}

cmd_ping() {
  local server_ip="" domain="" sni=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain)  domain="$2"; shift 2 ;;
      --sni)     sni="$2"; shift 2 ;;
      -*)        fail "Unknown flag: $1" ;;
      *)         server_ip="$1"; shift ;;
    esac
  done

  # Resolve server IP
  if [[ -n "$server_ip" ]]; then
    SERVER_IP="$server_ip"
  else
    resolve_server || fail "Server IP required. Usage: meridian ping IP"
  fi

  # Try to load saved credentials for domain and SNI
  local creds_dir
  creds_dir=$(server_creds)
  if [[ -f "$creds_dir/proxy.yml" ]]; then
    [[ -z "$domain" ]] && domain=$(grep '^domain:' "$creds_dir/proxy.yml" 2>/dev/null | awk '{print $2}' | tr -d '"' || true)
    [[ -z "$sni" ]] && sni=$(grep '^reality_sni:' "$creds_dir/proxy.yml" 2>/dev/null | awk '{print $2}' | tr -d '"' || true)
  fi

  local sni_host="${sni:-www.microsoft.com}"
  local issues=0
  local checks=0

  printf "  ${B}Ping${R}\n"
  printf "  ${D}Testing proxy reachability from this device${R}\n"
  printf "\n"

  # 0. Clock check (Reality requires client clock accurate within 30s)
  info "Checking device clock..."
  checks=$((checks + 1))
  local ref_date client_epoch ref_epoch clock_drift
  ref_date=$(curl -sI --max-time 5 "https://www.google.com/" 2>/dev/null | grep -i '^date:' | sed 's/^[Dd]ate: //' | tr -d '\r')
  client_epoch=$(date +%s)
  if [[ -n "$ref_date" ]]; then
    ref_epoch=$(date -d "$ref_date" +%s 2>/dev/null || date -j -f "%a, %d %b %Y %H:%M:%S %Z" "$ref_date" +%s 2>/dev/null || echo "")
    if [[ -n "$ref_epoch" && "$ref_epoch" =~ ^[0-9]+$ ]]; then
      clock_drift=$(( client_epoch - ref_epoch ))
      [[ $clock_drift -lt 0 ]] && clock_drift=$(( -clock_drift ))
      if [[ $clock_drift -gt 30 ]]; then
        warn "Device clock is off by ${clock_drift}s (Reality needs <30s)"
        printf "       %s\n" "Enable automatic date/time in your device settings."
        issues=$((issues + 1))
      else
        ok "Device clock OK"
      fi
    else
      ok "Clock check skipped (date parsing unavailable)"
    fi
  else
    ok "Clock check skipped (offline)"
  fi

  # 1. TCP connect to port 443
  info "Connecting to $SERVER_IP:443..."
  checks=$((checks + 1))
  if timeout 5 bash -c "echo >/dev/tcp/$SERVER_IP/443" 2>/dev/null; then
    ok "Port 443 is reachable"
  else
    warn "Port 443 is not reachable"
    printf "       %s\n" "Possible causes:"
    printf "       %s\n" "- Cloud firewall / security group blocks port 443"
    printf "       %s\n" "- Your ISP or network blocks this server's IP"
    printf "       %s\n" "- Server is down or proxy is not running"
    issues=$((issues + 1))
  fi

  # 2. TLS handshake — Reality should present the SNI target's certificate
  info "Checking TLS handshake (Reality → $sni_host)..."
  checks=$((checks + 1))
  local tls_result
  tls_result=$(timeout 5 bash -c "echo | openssl s_client -connect $SERVER_IP:443 -servername $sni_host 2>/dev/null" || true)
  if [[ "$tls_result" == *"CONNECTED"* && "$tls_result" == *"Certificate chain"* ]]; then
    local cert_cn
    cert_cn=$(echo "$tls_result" | grep -m1 'subject=' | sed 's/.*CN = //' || true)
    ok "TLS handshake OK${cert_cn:+ (cert: $cert_cn)}"
  elif [[ "$tls_result" == *"CONNECTED"* ]]; then
    ok "TLS handshake OK"
  else
    warn "TLS handshake failed"
    printf "       %s\n" "Reality proxy may not be running, or connection is blocked."
    issues=$((issues + 1))
  fi

  # 3. If domain mode, check HTTPS to the domain
  if [[ -n "$domain" ]]; then
    info "Checking domain https://$domain/ ..."
    checks=$((checks + 1))
    local http_code
    http_code=$(curl -sSf -o /dev/null -w '%{http_code}' --connect-timeout 5 --max-time 10 "https://$domain/" 2>/dev/null || echo "000")
    if [[ "$http_code" =~ ^[23] ]]; then
      ok "Domain is responding (HTTP $http_code)"
    elif [[ "$http_code" == "000" ]]; then
      warn "Domain is not reachable"
      printf "       %s\n" "Check DNS settings and that Caddy is running on the server."
      issues=$((issues + 1))
    else
      warn "Domain returned HTTP $http_code"
      issues=$((issues + 1))
    fi
  fi

  # Summary
  printf "\n"
  if [[ "$issues" -eq 0 ]]; then
    printf "  ${G}All $checks checks passed.${R} Server is reachable from this device.\n"
    printf "  ${D}If your VPN client can't connect, the issue is likely:${R}\n"
    printf "  ${D}  - Incorrect connection link (re-scan the QR code)${R}\n"
    printf "  ${D}  - VPN app misconfiguration (try v2rayNG or Hiddify)${R}\n"
  else
    printf "  ${RED}$issues issue(s) found.${R} The server is not fully reachable from this device.\n"
    printf "  ${D}This means the problem is between your device and the server,${R}\n"
    printf "  ${D}not with the Meridian deployment itself.${R}\n"
    printf "\n"
    printf "  ${D}Common fixes:${R}\n"
    printf "  ${D}  - Open port 443/TCP in your cloud provider's firewall${R}\n"
    printf "  ${D}  - Try from a different network (mobile data, another Wi-Fi)${R}\n"
    printf "  ${D}  - Your ISP may be blocking this server's IP — try a different server${R}\n"
  fi
  printf "\n"
}

