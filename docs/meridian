# =============================================================================
# Main dispatch
# =============================================================================

main() {
  mkdir -p "$MERIDIAN_HOME"

  # Parse global --server flag from anywhere in args
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --server) [[ $# -ge 2 ]] || fail "--server requires a value"; REQUESTED_SERVER="$2"; shift 2 ;;
      *)        args+=("$1"); shift ;;
    esac
  done
  set -- ${args[@]+"${args[@]}"}

  local cmd="${1:-}"
  shift || true

  # Banner
  printf "\n"
  printf "  ${B}Meridian${R} ${D}v${MERIDIAN_VERSION}${R}\n"
  printf "\n"

  # Check for updates (non-blocking, for non-meta commands)
  case "$cmd" in
    self-update|version|help|"") ;;
    *) check_for_update ;;
  esac

  # Re-exec after auto-update so new MERIDIAN_VERSION is used for playbook download
  if [[ "${MERIDIAN_AUTO_UPDATED:-}" == 1 ]]; then
    exec "$0" ${args[@]+"${args[@]}"}
  fi

  # Dispatch
  case "$cmd" in
    setup)        cmd_setup "$@" ;;
    client)       cmd_client "$@" ;;
    server)       cmd_server "$@" ;;
    check)        cmd_check "$@" ;;
    scan)         cmd_scan "$@" ;;
    ping)         cmd_ping "$@" ;;
    diagnostics)  cmd_diagnostics "$@" ;;
    uninstall)    cmd_uninstall "$@" ;;
    self-update)  cmd_self_update ;;
    version)      cmd_version ;;
    help|--help|-h|"") cmd_help ;;
    *)            fail "Unknown command: $cmd. Run: meridian help" ;;
  esac
}

main "$@"
